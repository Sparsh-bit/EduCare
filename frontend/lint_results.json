))}\n                            </motion.div>\n                        )}\n                    </AnimatePresence>\n                </div>\n            </div>\n\n            <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-10\">\n                {/* Center / Partition Panel */}\n                <div className=\"lg:col-span-8 space-y-10\">\n                    <AnimatePresence mode=\"wait\">\n                        {selectedStudent ? (\n                            <motion.div initial={{ opacity: 0, x: -20 }} animate={{ opacity: 1, x: 0 }} className=\"space-y-10\">\n                                {/* Unit Profile Panel */}\n                                <div className=\"premium-panel p-10 bg-[#003d73] text-white overflow-hidden relative group\">\n                                    <div className=\"absolute top-0 right-0 p-10 opacity-5 group-hover:scale-110 transition-transform\">\n                                        <ShieldCheck size={140} />\n                                    </div>\n                                    <div className=\"flex flex-col md:flex-row gap-10 items-center relative z-10\">\n                                        <div className=\"w-28 h-28 bg-[#84cc16] rounded-[2.5rem] flex items-center justify-center text-[#003d73] text-4xl font-black shadow-2xl shadow-black/20\">\n                                            {selectedStudent.name.charAt(0)}\n                                        </div>\n                                        <div className=\"text-center md:text-left flex-1\">\n                                            <h2 className=\"text-3xl font-black tracking-tighter mb-2\">{selectedStudent.name}</h2>\n                                            <div className=\"flex flex-wrap items-center justify-center md:justify-start gap-3\">\n                                                <span className=\"px-3 py-1 rounded-full bg-white/10 text-[10px] font-black uppercase tracking-widest\">Class {selectedStudent.class_name}</span>\n                                                <span className=\"px-3 py-1 rounded-full bg-white/10 text-[10px] font-black uppercase tracking-widest text-[#84cc16]\">Branch {selectedStudent.section_name}</span>\n                                            </div>\n                                            <div className=\"flex gap-8 mt-6\">\n                                                <div>\n                                                    <p className=\"text-[9px] font-black uppercase tracking-widest opacity-40 mb-1\">Adm Ident</p>\n                                                    <p className=\"text-sm font-black font-mono\">{selectedStudent.admission_no}</p>\n                                                </div>\n                                                <div>\n                                                    <p className=\"text-[9px] font-black uppercase tracking-widest opacity-40 mb-1\">Guardian</p>\n                                                    <p className=\"text-sm font-black\">{selectedStudent.father_name}</p>\n                                                </div>\n                                            </div>\n                                        </div>\n                                        \n                                        <div className=\"grid grid-cols-1 gap-px bg-white/10 rounded-3xl overflow-hidden shadow-2xl border border-white/5\">\n                                            <div className=\"bg-white/5 p-6 min-w-[160px] text-center\">\n                                                <p className=\"text-[9px] font-black uppercase tracking-[0.2em] text-[#84cc16] mb-1 leading-none\">Vested</p>\n                                                <p className=\"text-2xl font-black tracking-tighter leading-none\">₹{feeStatus?.total_paid || 0}</p>\n                                            </div>\n                                            <div className=\"bg-[#84cc16]/10 p-6 min-w-[160px] text-center\">\n                                                <p className=\"text-[9px] font-black uppercase tracking-[0.2em] text-rose-300 mb-1 leading-none\">Awaiting</p>\n                                                <p className=\"text-2xl font-black tracking-tighter leading-none\">₹{feeStatus?.total_due || 0}</p>\n                                            </div>\n                                        </div>\n                                    </div>\n                                </div>\n\n                                {/* Partitions */}\n                                <div className=\"premium-panel p-10 bg-white\">\n                                    <div className=\"flex items-center justify-between mb-10\">\n                                        <h3 className=\"text-2xl font-black text-[#003d73] tracking-tighter\">Fiscal Partitions</h3>\n                                        <div className=\"flex items-center gap-2 px-4 py-2 rounded-2xl bg-gray-50 text-[10px] font-black uppercase tracking-widest text-gray-400\">\n                                            <Clock size={14} className=\"text-[#84cc16]\" />\n                                            Select to initiate pay\n                                        </div>\n                                    </div>\n                                    \n                                    <div className=\"grid grid-cols-1 md:grid-cols-2 gap-6\">\n                                        {feeStatus?.installments?.map((inst) => (\n                                            <button\n                                                key={inst.id}\n                                                disabled={inst.paid}\n                                                onClick={() => toggleInstallment(inst.id)}\n                                                className={`\n                                                    p-8 rounded-[2.5rem] border-2 transition-all relative group\n                                                    ${inst.paid\n                                                        ? \"bg-gray-50/50 border-transparent grayscale opacity-50 cursor-not-allowed\"\n                                                        : selectedInstallments.includes(inst.id)\n                                                            ? \"bg-[#003d73] border-[#003d73] shadow-2xl shadow-[#003d73]/20\"\n                                                            : \"bg-white border-gray-50 hover:border-[#003d73]/10 hover:shadow-xl hover:shadow-[#003d73]/5\"}\n                                                `}\n                                            >\n                                                <div className=\"flex items-start justify-between mb-6\">\n                                                    <div className={`w-12 h-12 rounded-2xl flex items-center justify-center font-black ${selectedInstallments.includes(inst.id) ? \"bg-[#84cc16] text-[#003d73]\" : \"bg-gray-100 text-gray-400\"}`}>\n                                                        {inst.installment_no}\n                                                    </div>\n                                                    {inst.paid && <CheckCircle2 size={24} className=\"text-emerald-500\" />}\n                                                </div>\n                                                \n                                                <div className=\"text-left\">\n                                                    <p className={`text-[10px] font-black uppercase tracking-[0.3em] mb-2 ${selectedInstallments.includes(inst.id) ? \"text-white/40\" : \"text-gray-300\"}`}>Partition #{inst.installment_no}</p>\n                                                    <p className={`text-2xl font-black tracking-tighter mb-1 ${selectedInstallments.includes(inst.id) ? \"text-white\" : \"text-[#003d73]\"}`}>₹{(inst.amount || 0).toLocaleString()}</p>\n                                                    <p className={