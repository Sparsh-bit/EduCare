234,2237],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[2234,2237],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}],"suppressions":[{"kind":"directive","justification":""}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":44,"column":65,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":44,"endColumn":68,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[2318,2321],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[2318,2321],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}],"suppressions":[{"kind":"directive","justification":""}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":45,"column":61,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":45,"endColumn":64,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[2398,2401],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[2398,2401],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}],"suppressions":[{"kind":"directive","justification":""}]}],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"/* eslint-disable @typescript-eslint/no-explicit-any */\n'use client';\nimport { useState, useEffect, useCallback } from 'react';\nimport { API_BASE } from '@/lib/runtimeConfig';\nimport { authStorage } from '@/lib/authStorage';\n\nconst API = API_BASE;\nconst getToken = () => authStorage.getToken() ?? '';\nconst authHeaders = () => ({ 'Content-Type': 'application/json', Authorization: `Bearer ${getToken()}` });\n\nconst TABS = ['Instruments', 'Bounced Cheques', 'Bank Reconciliation', 'UPI QR'] as const;\ntype Tab = typeof TABS[number];\n\nexport default function AdvancedPaymentsPage() {\n  const [activeTab, setActiveTab] = useState<Tab>('Instruments');\n  const [loading, setLoading] = useState(false);\n  const [success, setSuccess] = useState('');\n  const [error, setError] = useState('');\n\n  // Instruments\n  const [instruments, setInstruments] = useState<Record<string, any>[]>([]);\n  const [instFilter, setInstFilter] = useState({ instrument_type: '', date_from: '', date_to: '', status: '' });\n  const [updateModal, setUpdateModal] = useState<Record<string, any> | null>(null);\n  const [updateForm, setUpdateForm] = useState({ instrument_type: '', instrument_number: '', bank_name: '', instrument_date: '' });\n  const [clearModal, setClearModal] = useState<Record<string, any> | null>(null);\n  const [clearForm, setClearForm] = useState({ action: 'clear', clearance_date: '', bounce_penalty: '' });\n\n  // Bounced Cheques\n  const [bouncedList, setBouncedList] = useState<Record<string, any>[]>([]);\n\n  // Bank Reconciliation\n  const [csvText, setCsvText] = useState('');\n  const [importModal, setImportModal] = useState(false);\n  const [unreconciled, setUnreconciled] = useState<Record<string, any>[]>([]);\n  const [reconSummary, setReconSummary] = useState<Record<string, any> | null>(null);\n  const [matchModal, setMatchModal] = useState<Record<string, any> | null>(null);\n  const [matchSearch, setMatchSearch] = useState('');\n  const [matchResults, setMatchResults] = useState<Record<string, any>[]>([]);\n\n  // UPI QR\n  const [upiSearch, setUpiSearch] = useState('');\n  const [upiSearchResults, setUpiSearchResults] = useState<Record<string, any>[]>([]);\n  const [selectedUpiStudent, setSelectedUpiStudent] = useState<Record<string, any> | null>(null);\n  const [generatedQR, setGeneratedQR] = useState<Record<string, any> | null>(null);\n  const [recentQRs, setRecentQRs] = useState<Record<string, any>[]>([]);\n\n  const showMsg = (msg: string, isError = false) => {\n    if (isError) { setError(msg); setSuccess(''); } else { setSuccess(msg); setError(''); }\n    setTimeout(() => { setSuccess(''); setError(''); }, 3000);\n  };\n\n  const loadInstruments = useCallback(async () => {\n    setLoading(true);\n    try {\n      const params = new URLSearchParams();\n      if (instFilter.instrument_type) params.set('instrument_type', instFilter.instrument_type);\n      if (instFilter.date_from) params.set('date_from', instFilter.date_from);\n      if (instFilter.date_to) params.set('date_to', instFilter.date_to);\n      if (instFilter.status) params.set('status', instFilter.status);\n      const res = await fetch(`${API}/payment-instruments?${params}`, { headers: authHeaders() });\n      const d = await res.json();\n      setInstruments(d.data || []);\n    } catch { /* ignore */ }\n    setLoading(false);\n  }, [instFilter]);\n\n  const loadBounced = useCallback(async () => {\n    setLoading(true);\n    try {\n      const res = await fetch(`${API}/payment-instruments/bounced`, { headers: authHeaders() });\n      const d = await res.json();\n      setBouncedList(d.data || []);\n    } catch { /* ignore */ }\n    setLoading(false);\n  }, []);\n\n  const loadUnreconciled = useCallback(async () => {\n    setLoading(true);\n    try {\n      const [unreconRes, summaryRes] = await Promise.all([\n        fetch(`${API}/payment-instruments/bank-statements/unreconciled`, { headers: authHeaders() }),\n        fetch(`${API}/payment-instruments/bank-statements/summary`, { headers: authHeaders() }),\n      ]);\n      const un = await unreconRes.json();\n      const su = await summaryRes.json();\n      setUnreconciled(un.data || []);\n      setReconSummary(su.data || null);\n    } catch { /* ignore */ }\n    setLoading(false);\n  }, []);\n\n  const loadRecentQRs = useCallback(async () => {\n    try {\n      const res = await fetch(`${API}/payment-instruments/upi-qr/recent`, { headers: authHeaders() });\n      const d = await res.json();\n      setRecentQRs(d.data || []);\n    } catch { /* ignore */ }\n  }, []);\n\n  useEffect(() => {\n    if (activeTab === 'Instruments') loadInstruments();\n    else if (activeTab === 'Bounced Cheques') loadBounced();\n    else if (activeTab === 'Bank Reconciliation') loadUnreconciled();\n    else if (activeTab === 'UPI QR') loadRecentQRs();\n  }, [activeTab, loadInstruments, loadBounced, loadUnreconciled, loadRecentQRs]);\n\n  // UPI student search\n  useEffect(() => {\n    if (upiSearch.length < 3) { setUpiSearchResults([]); return; }\n    const t = setTimeout(async () => {\n      const res = await fetch(`${API}/students?search=${upiSearch}`, { headers: authHeaders() });\n      const d = await res.json();\n      setUpiSearchResults(d.data || d.students || []);\n    }, 300);\n    return () => clearTimeout(t);\n  }, [upiSearch]);\n\n  // Match search\n  useEffect(() => {\n    if (!matchModal || matchSearch.length < 3) { setMatchResults([]); return; }\n    const t = setTimeout(async () => {\n      const res = await fetch(`${API}/fees/payments?search=${matchSearch}`, { headers: authHeaders() });\n      const d = await res.json();\n      setMatchResults(d.data || []);\n    }, 300);\n    return () => clearTimeout(t);\n  }, [matchSearch, matchModal]);\n\n  const saveInstrument = async () => {\n    setLoading(true);\n    try {\n      const res = await fetch(`${API}/payment-instruments/${updateModal!.id}`, {\n        method: 'PUT', headers: authHeaders(), body: JSON.stringify(updateForm),\n      });\n      if (!res.ok) throw new Error((await res.json()).message || 'Update failed');\n      showMsg('Instrument updated.');\n      setUpdateModal(null);\n      loadInstruments();\n    } catch (e: unknown) { showMsg(e instanceof Error ? e.message : 'Operation failed', true); }\n    setLoading(false);\n  };\n\n  const clearOrBounce = async () => {\n    setLoading(true);\n    try {\n      const body = clearForm.action === 'clear'\n        ? { action: 'clear', clearance_date: clearForm.clearance_date }\n        : { action: 'bounce', bounce_penalty: clearForm.bounce_penalty };\n      const res = await fetch(`${API}/payment-instruments/${clearModal!.id}/status`, {\n        method: 'PUT', headers: authHeaders(), body: JSON.stringify(body),\n      });\n      if (!res.ok) throw new Error((await res.json()).message || 'Update failed');\n      showMsg(clearForm.action === 'clear' ? 'Cleared successfully.' : 'Marked as bounced.');\n      setClearModal(null);\n      loadInstruments();\n    } catch (e: unknown) { showMsg(e instanceof Error ? e.message : 'Operation failed', true); }\n    setLoading(false);\n  };\n\n  const sendSmsReminder = async (id: number) => {\n    try {\n      await fetch(`${API}/communication/send`, {\n        method: 'POST', headers: authHeaders(), body: JSON.stringify({ type: 'bounce_reminder', instrument_id: id }),\n      });\n      showMsg('SMS reminder sent.');\n    } catch (e: unknown) { showMsg(e instanceof Error ? e.message : 'Operation failed', true); }\n  };\n\n  const parseAndImportCSV = async () => {\n    const lines = csvText.trim().split('\\n').slice(1); // skip header\n    const rows = lines.map(line => {\n      const [date, description, credit, debit, balance, reference] = line.split(',').map(s => s.trim());\n      return { date, description, credit: Number(credit) || 0, debit: Number(debit) || 0, balance: Number(balance) || 0, reference };\n    });\n    setLoading(true);\n    try {\n      const res = await fetch(`${API}/payment-instruments/bank-statements`, {\n        method: 'POST', headers: authHeaders(), body: JSON.stringify(rows),\n      });\n      if (!res.ok) throw new Error((await res.json()).message || 'Import failed');\n      showMsg(`${rows.length} statements imported.`);\n      setImportModal(false);\n      setCsvText('');\n      loadUnreconciled();\n    } catch (e: unknown) { showMsg(e instanceof Error ? e.message : 'Operation failed', true); }\n    setLoading(false);\n  };\n\n  const reconcile = async (statementId: number, paymentId: number) => {\n    setLoading(true);\n    try {\n      const res = await fetch(`${API}/payment-instruments/bank-statements/${statementId}/reconcile`, {\n        method: 'PUT', headers: authHeaders(), body: JSON.stringify({ payment_id: paymentId }),\n      });\n      if (!res.ok) throw new Error('Reconciliation failed');\n      showMsg('Entry reconciled.');\n      setMatchModal(null);\n      loadUnreconciled();\n    } catch (e: unknown) { showMsg(e instanceof Error ? e.message : 'Operation failed', true); }\n    setLoading(false);\n  };\n\n  const generateQR = async () => {\n    if (!selectedUpiStudent) { showMsg('Select a student first.', true); return; }\n    setLoading(true);\n    try {\n      const res = await fetch(`${API}/payment-instruments/upi-qr/${selectedUpiStudent!.id}`, {\n        method: 'POST', headers: authHeaders(),\n      });\n      const d = await res.json();\n      if (!res.ok) throw new Error(d.message || 'QR generation failed');\n      setGeneratedQR(d.data || d);\n      loadRecentQRs();\n    } catch (e: unknown) { showMsg(e instanceof Error ? e.message : 'Operation failed', true); }\n    setLoading(false);\n  };\n\n  return (\n    <div className=\"space-y-6\">\n      <h1 className=\"text-2xl font-bold text-gray-900\">Advanced Payment Management</h1>\n\n      {/* Tabs */}\n      <div className=\"flex gap-1 bg-gray-100 p-1 rounded-xl w-fit flex-wrap\">\n        {TABS.map(tab => (\n          <button key={tab} onClick={() => setActiveTab(tab)}\n            className={`px-4 py-2 text-sm font-medium rounded-lg transition-all ${activeTab === tab ? 'bg-white text-[#6c5ce7] shadow-sm' : 'text-gray-500 hover:text-gray-700'}`}>\n            {tab}\n          </button>\n        ))}\n      </div>\n\n      {success && <div className=\"px-4 py-3 rounded-xl text-sm bg-emerald-50 text-emerald-700 border border-emerald-200\">{success}</div>}\n      {error && <div className=\"px-4 py-3 rounded-xl text-sm bg-red-50 text-red-700 border border-red-200\">{error}</div>}\n\n      {/* ── Instruments ── */}\n      {activeTab === 'Instruments' && (\n        <div className=\"space-y-4\">\n          <div className=\"bg-white rounded-2xl border border-gray-200 shadow-sm p-4 flex flex-wrap gap-3 items-end\">\n            <div>\n              <label className=\"block text-xs font-medium text-gray-600 mb-1\">Type</label>\n              <select value={instFilter.instrument_type} onChange={e => setInstFilter({ ...instFilter, instrument_type: e.target.value })}\n                className=\"px-3 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-[#6c5ce7]/20 focus:border-[#6c5ce7]\">\n                <option value=\"\">All Types</option>\n                {['cash','cheque','online','bank_transfer','upi','dd'].map(t => <option key={t} value={t}>{t.toUpperCase()}</option>)}\n              </select>\n            </div>\n            <div>\n              <label className=\"block text-xs font-medium text-gray-600 mb-1\">From</label>\n              <input type=\"date\" value={instFilter.date_from} onChange={e => setInstFilter({ ...instFilter, date_from: e.target.value })}\n                className=\"px-3 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-[#6c5ce7]/20 focus:border-[#6c5ce7]\" />\n            </div>\n            <div>\n              <label className=\"block text-xs font-medium text-gray-600 mb-1\">To</label>\n              <input type=\"date\" value={instFilter.date_to} onChange={e => setInstFilter({ ...instFilter, date_to: e.target.value })}\n                className=\"px-3 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-[#6c5ce7]/20 focus:border-[#6c5ce7]\" />\n            </div>\n            <div>\n              <label className=\"block text-xs font-medium text-gray-600 mb-1\">Status</label>\n              <select value={instFilter.status} onChange={e => setInstFilter({ ...instFilter, status: e.target.value })}\n                className=\"px-3 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-[#6c5ce7]/20 focus:border-[#6c5ce7]\">\n                <option value=\"\">All</option>\n                {['pending','cleared','bounced'].map(s => <option key={s} value={s}>{s}</option>)}\n              </select>\n            </div>\n            <button onClick={loadInstruments} disabled={loading}\n              className=\"px-4 py-2 bg-[#6c5ce7] text-white text-sm font-medium rounded-xl hover:bg-[#5a4bd1] disabled:opacity-60\">\n              Filter\n            </button>\n          </div>\n\n          <div className=\"bg-white rounded-2xl border border-gray-200 shadow-sm overflow-x-auto\">\n            <table className=\"w-full text-sm min-w-max\">\n              <thead>\n                <tr className=\"bg-gray-50/80 text-gray-600 font-medium border-b border-gray-200\">\n                  <th className=\"px-4 py-3 text-left\">Receipt No</th>\n                  <th className=\"px-4 py-3 text-left\">Student</th>\n                  <th className=\"px-4 py-3 text-right\">Amount</th>\n                  <th className=\"px-4 py-3 text-left\">Type</th>\n                  <th className=\"px-4 py-3 text-left\">Instrument No</th>\n                  <th className=\"px-4 py-3 text-left\">Bank</th>\n                  <th className=\"px-4 py-3 text-left\">Date</th>\n                  <th className=\"px-4 py-3 text-left\">Status</th>\n                  <th className=\"px-4 py-3 text-left\">Actions</th>\n                </tr>\n              </thead>\n              <tbody className=\"divide-y divide-gray-100\">\n                {loading ? (\n                  <tr><td colSpan={9} className=\"px-4 py-8 text-center text-gray-400\">Loading...</td></tr>\n                ) : instruments.length === 0 ? (\n                  <tr><td colSpan={9} className=\"px-4 py-8 text-center text-gray-400\">No instruments found.</td></tr>\n                ) : instruments.map(inst => (\n                  <tr key={String(inst.id)} className=\"hover:bg-gray-50/50\">\n                    <td className=\"px-4 py-3 font-mono text-xs text-gray-700\">{String(inst.receipt_no || '')}</td>\n                    <td className=\"px-4 py-3 font-medium text-gray-800\">{String(inst.student_name || '')}</td>\n                    <td className=\"px-4 py-3 text-right font-semibold\">₹{Number(inst.amount).toLocaleString('en-IN')}</td>\n                    <td className=\"px-4 py-3\"><span className=\"px-2 py-1 bg-purple-50 text-[#6c5ce7] text-xs rounded-lg\">{String(inst.instrument_type || inst.payment_mode || '')}</span></td>\n                    <td className=\"px-4 py-3 text-gray-600 font-mono text-xs\">{String(inst.instrument_number || '-')}</td>\n                    <td className=\"px-4 py-3 text-gray-600\">{String(inst.bank_name || '-')}</td>\n                    <td className=\"px-4 py-3 text-gray-600\">{String(inst.instrument_date || inst.payment_date || '')}</td>\n                    <td className=\"px-4 py-3\">\n                      <span className={`px-2 py-1 text-xs font-medium rounded-lg ${inst.status === 'cleared' ? 'bg-emerald-50 text-emerald-700' : inst.status === 'bounced' ? 'bg-red-50 text-red-700' : 'bg-amber-50 text-amber-700'}`}>\n                        {String(inst.status || 'pending')}\n                      </span>\n                    </td>\n                    <td className=\"px-4 py-3\">\n                      <div className=\"flex gap-2\">\n                        <button onClick={() => { setUpdateModal(inst); setUpdateForm({ instrument_type: String(inst.instrument_type || ''), instrument_number: String(inst.instrument_number || ''), bank_name: String(inst.bank_name || ''), instrument_date: String(inst.instrument_date || '') }); }}\n                          className=\"px-2 py-1 text-xs bg-gray-100 text-gray-700 rounded-lg hover:bg-gray-200\">Update</button>\n                        <button onClick={() => { setClearModal(inst); setClearForm({ action: 'clear', clearance_date: '', bounce_penalty: '' }); }}\n                          className=\"px-2 py-1 text-xs bg-blue-50 text-blue-700 rounded-lg hover:bg-blue-100\">Clear/Bounce</button>\n                      </div>\n                    </td>\n                  </tr>\n                ))}\n              </tbody>\n            </table>\n          </div>\n        </div>\n      )}\n\n      {/* ── Bounced Cheques ── */}\n      {activeTab === 'Bounced Cheques' && (\n        <div className=\"bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden\">\n          <table className=\"w-full text-sm\">\n            <thead>\n              <tr className=\"bg-gray-50/80 text-gray-600 font-medium border-b border-gray-200\">\n                <th className=\"px-4 py-3 text-left\">Receipt</th>\n                <th className=\"px-4 py-3 text-left\">Student</th>\n                <th className=\"px-4 py-3 text-right\">Amount</th>\n                <th className=\"px-4 py-3 text-left\">Cheque No</th>\n                <th className=\"px-4 py-3 text-left\">Bank</th>\n                <th className=\"px-4 py-3 text-left\">Bounce Date</th>\n                <th className=\"px-4 py-3 text-right\">Penalty</th>\n                <th className=\"px-4 py-3 text-left\">Status</th>\n                <th className=\"px-4 py-3 text-left\">Action</th>\n              </tr>\n            </thead>\n            <tbody className=\"divide-y divide-gray-100\">\n              {loading ? (\n                <tr><td colSpan={9} className=\"px-4 py-8 text-center text-gray-400\">Loading...</td></tr>\n              ) : bouncedList.length === 0 ? (\n                <tr><td colSpan={9} className=\"px-4 py-8 text-center text-gray-400\">No bounced cheques found.</td></tr>\n              ) : bouncedList.map(item => (\n                <tr key={String(item.id)} className=\"hover:bg-gray-50/50\">\n                  <td className=\"px-4 py-3 font-mono text-xs\">{String(item.receipt_no || '')}</td>\n                  <td className=\"px-4 py-3 font-medium text-gray-800\">{String(item.student_name || '')}</td>\n                  <td className=\"px-4 py-3 text-right font-semibold\">₹{Number(item.amount).toLocaleString('en-IN')}</td>\n                  <td className=\"px-4 py-3 font-mono text-xs text-gray-600\">{String(item.instrument_number || '')}</td>\n                  <td className=\"px-4 py-3 text-gray-600\">{String(item.bank_name || '')}</td>\n                  <td className=\"px-4 py-3 text-gray-600\">{String(item.bounce_date || item.instrument_date || '')}</td>\n                  <td className=\"px-4 py-3 text-right text-red-600 font-medium\">₹{Number(item.bounce_penalty || 0).toLocaleString('en-IN')}</td>\n                  <td className=\"px-4 py-3\"><span className=\"px-2 py-1 bg-red-50 text-red-700 text-xs font-medium rounded-lg\">Bounced</span></td>\n                  <td className=\"px-4 py-3\">\n                    <button onClick={() => sendSmsReminder(item.id as number)}\n                      className=\"px-3 py-1 text-xs bg-[#6c5ce7] text-white rounded-lg hover:bg-[#5a4bd1]\">\n                      SMS Reminder\n                    </button>\n                  </td>\n                </tr>\n              ))}\n            </tbody>\n          </table>\n        </div>\n      )}\n\n      {/* ── Bank Reconciliation ── */}\n      {activeTab === 'Bank Reconciliation' && (\n        <div className=\"space-y-4\">\n          {/* Summary */}\n          {reconSummary && (\n            <div className=\"grid grid-cols-3 gap-4\">\n              {([\n                { label: 'Total Credits', value: (reconSummary.total_credits as number) || 0, color: 'text-emerald-700' },\n                { label: 'Reconciled', value: (reconSummary.reconciled as number) || 0, color: 'text-blue-700' },\n                { label: 'Unreconciled', value: (reconSummary.unreconciled as number) || 0, color: 'text-amber-700' },\n              ] as Array<{ label: string; value: number; color: string }>).map(c => (\n                <div key={c.label} className=\"bg-white rounded-2xl border border-gray-200 shadow-sm p-4\">\n                  <p className=\"text-xs text-gray-500\">{c.label}</p>\n                  <p className={`text-xl font-bold mt-1 ${c.color}`}>{c.value}</p>\n                </div>\n              ))}\n            </div>\n          )}\n\n          <div className=\"flex justify-end\">\n            <button onClick={() => setImportModal(true)}\n              className=\"px-4 py-2 bg-[#6c5ce7] text-white text-sm font-medium rounded-xl hover:bg-[#5a4bd1]\">\n              Import Statement\n            </button>\n          </div>\n\n          <div className=\"bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden\">\n            <table className=\"w-full text-sm\">\n              <thead>\n                <tr className=\"bg-gray-50/80 text-gray-600 font-medium border-b border-gray-200\">\n                  <th className=\"px-4 py-3 text-left\">Date</th>\n                  <th className=\"px-4 py-3 text-left\">Description</th>\n                  <th className=\"px-4 py-3 text-right\">Credit</th>\n                  <th className=\"px-4 py-3 text-left\">Reference</th>\n                  <th className=\"px-4 py-3 text-left\">Action</th>\n                </tr>\n              </thead>\n              <tbody className=\"divide-y divide-gray-100\">\n                {unreconciled.length === 0 ? (\n                  <tr><td colSpan={5} className=\"px-4 py-8 text-center text-gray-400\">No unreconciled entries.</td></tr>\n                ) : unreconciled.map(entry => (\n                  <tr key={String(entry.id)} className=\"hover:bg-gray-50/50\">\n                    <td className=\"px-4 py-3 text-gray-600\">{String(entry.date || '')}</td>\n                    <td className=\"px-4 py-3 text-gray-800\">{String(entry.description || '')}</td>\n                    <td className=\"px-4 py-3 text-right text-emerald-700 font-semibold\">₹{Number(entry.credit).toLocaleString('en-IN')}</td>\n                    <td className=\"px-4 py-3 font-mono text-xs text-gray-500\">{String(entry.reference || '')}</td>\n                    <td className=\"px-4 py-3\">\n                      <button onClick={() => { setMatchModal(entry); setMatchSearch(''); setMatchResults([]); }}\n                        className=\"px-3 py-1 text-xs bg-[#6c5ce7] text-white rounded-lg hover:bg-[#5a4bd1]\">\n                        Match\n                      </button>\n                    </td>\n                  </tr>\n                ))}\n              </tbody>\n            </table>\n          </div>\n        </div>\n      )}\n\n      {/* ── UPI QR ── */}\n      {activeTab === 'UPI QR' && (\n        <div className=\"space-y-6\">\n          <div className=\"bg-white rounded-2xl border border-gray-200 shadow-sm p-6 space-y-4 max-w-lg\">\n            <h2 className=\"font-semibold text-gray-800\">Generate UPI QR Code</h2>\n            <div className=\"relative\">\n              <label className=\"block text-xs font-medium text-gray-600 mb-1\">Search Student</label>\n              <input type=\"text\" placeholder=\"Name or admission number...\" value={upiSearch}\n                onChange={e => setUpiSearch(e.target.value)}\n                className=\"w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-[#6c5ce7]/20 focus:border-[#6c5ce7]\" />\n              {upiSearchResults.length > 0 && (\n                <div className=\"absolute top-full left-0 right-0 z-10 bg-white border border-gray-200 rounded-lg shadow-lg mt-1 max-h-40 overflow-y-auto\">\n                  {upiSearchResults.map(s => (\n                    <button key={String(s.id)} onClick={() => { setSelectedUpiStudent(s); setUpiSearch(String(s.name || '')); setUpiSearchResults([]); }}\n                      className=\"w-full px-3 py-2 text-left text-sm hover:bg-gray-50 border-b last:border-0\">\n                      <span className=\"font-medium\">{String(s.name || '')}</span> <span className=\"text-gray-500 text-xs\">— {String(s.admission_no || '')} {String(s.class_name || '')}</span>\n                    </button>\n                  ))}\n                </div>\n              )}\n            </div>\n            {selectedUpiStudent && (\n              <div className=\"bg-purple-50 rounded-xl p-3 text-sm\">\n                <span className=\"text-gray-600\">Selected: </span>\n                <span className=\"font-semibold text-[#6c5ce7]\">{String(selectedUpiStudent.name || '')}</span>\n                <span className=\"text-gray-500 text-xs ml-2\">({String(selectedUpiStudent.admission_no || '')})</span>\n              </div>\n            )}\n            <button onClick={generateQR} disabled={loading || !selectedUpiStudent}\n              className=\"px-4 py-2 bg-[#6c5ce7] text-white text-sm font-medium rounded-xl hover:bg-[#5a4bd1] disabled:opacity-60\">\n              {loading ? 'Generating...' : 'Generate QR Code'}\n            </button>\n\n            {generatedQR && (\n              <div className=\"border border-gray-200 rounded-xl p-4 text-center space-y-3\">\n                <p className=\"text-sm font-medium text-gray-700\">QR Code Generated</p>\n                {generatedQR.qr_image_url ? (\n                  <img src={String(generatedQR.qr_image_url)} alt=\"UPI QR\" className=\"w-48 h-48 mx-auto border rounded-xl\" />\n                ) : (\n                  <div className=\"w-48 h-48 mx-auto bg-gray-100 rounded-xl flex items-center justify-center text-gray-400 text-sm\">QR Image</div>\n                )}\n                <p className=\"text-xs text-gray-500\">UPI ID: {String(generatedQR.upi_id || '')}</p>\n                <p className=\"text-xs text-gray-500\">Amount: ₹{Number(generatedQR.amount || 0).toLocaleString('en-IN')}</p>\n                <button onClick={() => window.print()}\n                  className=\"px-4 py-2 bg-gray-100 text-gray-700 text-sm font-medium rounded-xl hover:bg-gray-200\">\n                  Print QR\n                </button>\n              </div>\n            )}\n          </div>\n\n          {/* Recent QRs */}\n          {recentQRs.length > 0 && (\n            <div className=\"bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden\">\n              <div className=\"p-4 border-b border-gray-100\">\n                <h2 className=\"font-semibold text-gray-800\">Recently Generated QR Codes</h2>\n              </div>\n              <table className=\"w-full text-sm\">\n                <thead>\n                  <tr className=\"bg-gray-50/80 text-gray-600 font-medium border-b border-gray-200\">\n                    <th className=\"px-4 py-3 text-left\">Student</th>\n                    <th className=\"px-4 py-3 text-right\">Amount</th>\n                    <th className=\"px-4 py-3 text-left\">UPI ID</th>\n                    <th className=\"px-4 py-3 text-left\">Generated</th>\n                  </tr>\n                </thead>\n                <tbody className=\"divide-y divide-gray-100\">\n                  {recentQRs.map((qr, i) => (\n                    <tr key={i} className=\"hover:bg-gray-50/50\">\n                      <td className=\"px-4 py-3 font-medium text-gray-800\">{String(qr.student_name || '')}</td>\n                      <td className=\"px-4 py-3 text-right font-semibold\">₹{Number(qr.amount || 0).toLocaleString('en-IN')}</td>\n                      <td className=\"px-4 py-3 text-gray-600 font-mono text-xs\">{String(qr.upi_id || '')}</td>\n                      <td className=\"px-4 py-3 text-gray-500 text-xs\">{String(qr.created_at || '')}</td>\n                    </tr>\n                  ))}\n                </tbody>\n              </table>\n            </div>\n          )}\n        </div>\n      )}\n\n      {/* ── Update Instrument Modal ── */}\n      {updateModal && (\n        <div className=\"fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4\">\n          <div className=\"bg-white rounded-2xl shadow-2xl w-full max-w-md p-6 space-y-4\">\n            <h2 className=\"font-bold text-gray-900\">Update Instrument Details</h2>\n            {([['instrument_type','Instrument Type'],['instrument_number','Instrument Number'],['bank_name','Bank Name'],['instrument_date','Instrument Date']] as [string,string][]).map(([k, label]) => (\n              <div key={k}>\n                <label className=\"block text-xs font-medium text-gray-600 mb-1\">{label}</label>\n                {k === 'instrument_type' ? (\n                  <select value={updateForm[k as keyof typeof updateForm]} onChange={e => setUpdateForm({ ...updateForm, [k]: e.target.value })}\n                    className=\"w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-[#6c5ce7]/20 focus:border-[#6c5ce7]\">\n                    <option value=\"\">Select</option>\n                    {['cash','cheque','online','bank_transfer','upi','dd'].map(t => <option key={t} value={t}>{t.toUpperCase()}</option>)}\n                  </select>\n                ) : (\n                  <input type={k === 'instrument_date' ? 'date' : 'text'} value={updateForm[k as keyof typeof updateForm]}\n                    onChange={e => setUpdateForm({ ...updateForm, [k]: e.target.value })}\n                    className=\"w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-[#6c5ce7]/20 focus:border-[#6c5ce7]\" />\n                )}\n              </div>\n            ))}\n            <div className=\"flex justify-end gap-2\">\n              <button onClick={() => setUpdateModal(null)} className=\"px-4 py-2 text-sm bg-gray-100 text-gray-700 rounded-xl hover:bg-gray-200\">Cancel</button>\n              <button onClick={saveInstrument} disabled={loading}\n                className=\"px-4 py-2 bg-[#6c5ce7] text-white text-sm font-medium rounded-xl hover:bg-[#5a4bd1] disabled:opacity-60\">\n                {loading ? 'Saving...' : 'Save'}\n              </button>\n            </div>\n          </div>\n        </div>\n      )}\n\n      {/* ── Clear/Bounce Modal ── */}\n      {clearModal && (\n        <div className=\"fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4\">\n          <div className=\"bg-white rounded-2xl shadow-2xl w-full max-w-sm p-6 space-y-4\">\n            <h2 className=\"font-bold text-gray-900\">Clear / Bounce Instrument</h2>\n            <div className=\"flex gap-3\">\n              {['clear','bounce'].map(a => (\n                <button key={a} onClick={() => setClearForm({ ...clearForm, action: a })}\n                  className={`px-4 py-2 text-sm font-medium rounded-xl border ${clearForm.action === a ? 'bg-[#6c5ce7] text-white border-[#6c5ce7]' : 'bg-white text-gray-700 border-gray-200 hover:border-gray-300'}`}>\n                  {a === 'clear' ? 'Mark Cleared' : 'Mark Bounced'}\n                </button>\n              ))}\n            </div>\n            {clearForm.action === 'clear' ? (\n              <div>\n                <label className=\"block text-xs font-medium text-gray-600 mb-1\">Clearance Date</label>\n                <input type=\"date\" value={clearForm.clearance_date} onChange={e => setClearForm({ ...clearForm, clearance_date: e.target.value })}\n                  className=\"w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-[#6c5ce7]/20 focus:border-[#6c5ce7]\" />\n              </div>\n            ) : (\n              <div>\n                <label className=\"block text-xs font-medium text-gray-600 mb-1\">Bounce Penalty (₹)</label>\n                <input type=\"number\" value={clearForm.bounce_penalty} onChange={e => setClearForm({ ...clearForm, bounce_penalty: e.target.value })}\n                  className=\"w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-[#6c5ce7]/20 focus:border-[#6c5ce7]\" />\n              </div>\n            )}\n            <div className=\"flex justify-end gap-2\">\n              <button onClick={() => setClearModal(null)} className=\"px-4 py-2 text-sm bg-gray-100 text-gray-700 rounded-xl hover:bg-gray-200\">Cancel</button>\n              <button onClick={clearOrBounce} disabled={loading}\n                className=\"px-4 py-2 bg-[#6c5ce7] text-white text-sm font-medium rounded-xl hover:bg-[#5a4bd1] disabled:opacity-60\">\n                {loading ? 'Saving...' : 'Confirm'}\n              </button>\n            </div>\n          </div>\n        </div>\n      )}\n\n      {/* ── Import Statement Modal ── */}\n      {importModal && (\n        <div className=\"fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4\">\n          <div className=\"bg-white rounded-2xl shadow-2xl w-full max-w-lg p-6 space-y-4\">\n            <h2 className=\"font-bold text-gray-900\">Import Bank Statement (CSV)</h2>\n            <p className=\"text-xs text-gray-500\">Format: date, description, credit, debit, balance, reference (one row per line, first row is header)</p>\n            <textarea rows={10} value={csvText} onChange={e => setCsvText(e.target.value)}\n              placeholder=\"date,description,credit,debit,balance,reference&#10;2025-01-01,Fee Payment,5000,0,50000,REF001\"\n              className=\"w-full px-3 py-2 border border-gray-200 rounded-lg text-sm font-mono focus:ring-2 focus:ring-[#6c5ce7]/20 focus:border-[#6c5ce7] resize-none\" />\n            <div className=\"flex justify-end gap-2\">\n              <button onClick={() => setImportModal(false)} className=\"px-4 py-2 text-sm bg-gray-100 text-gray-700 rounded-xl hover:bg-gray-200\">Cancel</button>\n              <button onClick={parseAndImportCSV} disabled={loading || !csvText.trim()}\n                className=\"px-4 py-2 bg-[#6c5ce7] text-white text-sm font-medium rounded-xl hover:bg-[#5a4bd1] disabled:opacity-60\">\n                {loading ? 'Importing...' : 'Import'}\n              </button>\n            </div>\n          </div>\n        </div>\n      )}\n\n      {/* ── Match Modal ── */}\n      {matchModal && (\n        <div className=\"fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4\">\n          <div className=\"bg-white rounded-2xl shadow-2xl w-full max-w-lg p-6 space-y-4\">\n            <h2 className=\"font-bold text-gray-900\">Match Entry — {String(matchModal.description || '')}</h2>\n            <p className=\"text-sm text-gray-600\">Amount: <span className=\"font-semibold text-emerald-700\">₹{Number(matchModal.credit).toLocaleString('en-IN')}</span></p>\n            <div>\n              <label className=\"block text-xs font-medium text-gray-600 mb-1\">Search Fee Payment</label>\n              <input type=\"text\" placeholder=\"Student name or amount...\" value={matchSearch} onChange={e => setMatchSearch(e.target.value)}\n                className=\"w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-[#6c5ce7]/20 focus:border-[#6c5ce7]\" />\n            </div>\n            {matchResults.length > 0 && (\n              <div className=\"border border-gray-200 rounded-lg max-h-48 overflow-y-auto\">\n                {matchResults.map(p => (\n                  <div key={String(p.id)} className=\"flex items-center justify-between px-3 py-2 border-b last:border-0 hover:bg-gray-50\">\n                    <div>\n                      <p className=\"text-sm font-medium\">{String(p.student_name || '')}</p>\n                      <p className=\"text-xs text-gray-500\">{String(p.receipt_no || '')} — {String(p.payment_date || '')}</p>\n                    </div>\n                    <div className=\"flex items-center gap-3\">\n                      <span className=\"font-semibold text-sm\">₹{Number(p.amount_paid).toLocaleString('en-IN')}</span>\n                      <button onClick={() => reconcile(matchModal!.id as number, p.id as number)}\n                        className=\"px-3 py-1 text-xs bg-[#6c5ce7] text-white rounded-lg hover:bg-[#5a4bd1]\">\n                        Match\n                      </button>\n                    </div>\n                  </div>\n                ))}\n              </div>\n            )}\n            <div className=\"flex justify-end\">\n              <button onClick={() => setMatchModal(null)} className=\"px-4 py-2 text-sm bg-gray-100 text-gray-700 rounded-xl hover:bg-gray-200\">Cancel</button>\n            </div>\n          </div>\n        </div>\n      )}\n    </div>\n  );\n}\n","usedDeprecatedRules":[]},{"filePath":"/Volumes/Volume D/Concilio_Claud/ndps-erp/frontend/src/app/(dashboard)/rte/page.tsx","messages":[],"suppressedMessages":[{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":29,"column":65,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":29,"endColumn":68,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[1103,1106],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[1103,1106],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}],"suppressions":[{"kind":"directive","justification":""}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":32,"column":69,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":32,"endColumn":72,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[1293,1296],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"mess