</p>\n                </div>\n                {activeTab.id === f.id && (\n                    <motion.div \n                        layoutId=\"activeFeature\"\n                        className=\"absolute inset-x-0 bottom-0 h-1.5 bg-[#84cc16]\"\n                    />\n                )}\n              </button>\n            ))}\n          </div>\n\n          <div className=\"lg:w-2/3\">\n            <div className=\"relative h-full\">\n              <AnimatePresence mode=\"wait\">\n                <motion.div\n                  key={activeTab.id}\n                  initial={{ opacity: 0, x: 40 }}\n                  animate={{ opacity: 1, x: 0 }}\n                  exit={{ opacity: 0, x: -40 }}\n                  transition={{ duration: 0.6, ease: [0.22, 1, 0.36, 1] }}\n                  className=\"premium-panel h-full min-h-[600px] flex flex-col relative overflow-hidden ring-1 ring-[#003d73]/5\"\n                >\n                  <div className=\"p-12 md:p-16 flex-1 flex flex-col justify-between relative z-10\">\n                    <div>\n                        <h3 className=\"text-4xl font-black text-[#003d73] mb-6 tracking-tighter\">\n                            {activeTab.title}\n                        </h3>\n                        <p className=\"text-xl text-gray-400 font-bold mb-12 max-w-xl leading-relaxed\">\n                            {activeTab.longDesc}\n                        </p>\n                    </div>\n                    \n                    <div className=\"flex items-center gap-12 pt-12 border-t border-gray-50\">\n                        <div className=\"flex flex-col\">\n                            <span className=\"text-[10px] font-black uppercase tracking-widest text-gray-300 mb-2\">Protocol Status</span>\n                            <span className=\"flex items-center gap-2 text-xs font-black text-[#84cc16] uppercase tracking-widest\">\n                                <div className=\"w-1.5 h-1.5 rounded-full bg-[#84cc16] animate