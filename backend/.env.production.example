# ════════════════════════════════════════════════════════════
# EduCare ERP Backend — Production Environment Variables
# Copy this file, rename to .env, and fill in all values.
# NEVER commit the filled .env to version control.
# ════════════════════════════════════════════════════════════

NODE_ENV=production
PORT=5000

# ─── Trust Proxy ───────────────────────────────────────────
# Set to 1 when behind Railway / Render / Cloudflare proxy.
TRUST_PROXY=1

# ─── Database (Supabase) ───────────────────────────────────
# Use the Session pooler connection string from Supabase:
# Project → Settings → Database → Connection string → Session mode
DB_HOST=db.xxxxxxxxxxxxxxxxxxxx.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your-supabase-db-password
DB_SSL=true
DB_POOL_MIN=2
DB_POOL_MAX=20
DB_CONNECTION_TIMEOUT_MS=10000
DB_ACQUIRE_TIMEOUT_MS=30000
DB_IDLE_TIMEOUT_MS=30000

# ─── Supabase Client ──────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_KEY=your-supabase-anon-or-service-role-key

# ─── JWT Secrets (min 64 chars, cryptographically random) ─
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_CHAR_RANDOM_HEX
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# ─── Aadhaar Encryption Key (min 32 chars) ─────────────────
AADHAAR_ENCRYPTION_KEY=REPLACE_WITH_64_CHAR_RANDOM_HEX

# ─── CORS ─────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Include both the Vercel / custom domain URLs.
FRONTEND_URL=https://your-school.vercel.app,https://www.your-school-domain.com

# ─── Website Admission Integration ────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ERP_API_KEY=REPLACE_WITH_64_CHAR_RANDOM_HEX

# ─── Email (Resend) ───────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=EduCare by Concilio <EduCare@concilio.solutions>

# ─── Gemini AI ────────────────────────────────────────────
GEMINI_API_KEY=AIzaSy_xxxxxxxxxxxxxxxxxxxx

# ─── Payments (Razorpay) ──────────────────────────────────
ENABLE_ONLINE_PAYMENTS=false
# RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
# RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx

# ─── SMS (MSG91) ──────────────────────────────────────────
# MSG91_AUTH_KEY=xxxxxxxxxxxxxxxxxxxx
# MSG91_SENDER_ID=EDUCAR
# MSG91_TEMPLATE_ID=xxxxxxxxxxxxxxxxxxxx

# ─── Fee Configuration ────────────────────────────────────
LATE_FEE_PER_DAY=50
LATE_FEE_MAX=2000

# ─── File Uploads ─────────────────────────────────────────
# On AWS ECS Fargate: EFS is mounted at /mnt/efs/uploads (set in task definition)
# On Railway: use a persistent volume mounted at /app/uploads
UPLOAD_DIR=/mnt/efs/uploads
MAX_FILE_SIZE=5242880
IMPORT_MAX_FILE_SIZE=10485760

# ─── AWS S3 (optional — alternative to EFS for file storage) ──
# Set USE_S3=true to store uploads in S3 instead of local disk.
# On ECS, credentials come from the IAM task role — no explicit keys needed.
# For local dev, set AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY.
USE_S3=false
# S3_BUCKET=ndps-erp-uploads
# AWS_REGION=ap-south-1
# S3_CDN_URL=https://your-cdn.cloudfront.net
# AWS_ACCESS_KEY_ID=          # local dev only — leave blank on ECS
# AWS_SECRET_ACCESS_KEY=      # local dev only — leave blank on ECS

# ─── Logging (AWS CloudWatch) ─────────────────────────────
# Set LOG_TO_STDOUT=true on ECS so the awslogs driver captures all output.
LOG_TO_STDOUT=true

# ─── Database SSL ─────────────────────────────────────────
# Default: rejectUnauthorized=true. Set to false only if using a self-signed cert.
# DB_SSL_REJECT_UNAUTHORIZED=false

# ─── Rate Limiting (production defaults) ──────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_API_MAX=600
RATE_LIMIT_AUTH_MAX=40
RATE_LIMIT_SENSITIVE_AUTH_MAX=20
RATE_LIMIT_HIGH_VALUE_MAX=300
RATE_LIMIT_MUTATION_MAX=120
