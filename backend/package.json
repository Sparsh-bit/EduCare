{
  "name": "ndps-erp-backend",
  "version": "1.0.0",
  "description": "New Defence Public School ERP - Backend API",
  "main": "dist/app.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/app.ts",
    "build": "tsc && echo '{\"type\":\"commonjs\"}' > dist/package.json",
    "start": "node dist/app.js",
    "migrate": "knex migrate:latest --knexfile knexfile.cjs",
    "migrate:rollback": "knex migrate:rollback --knexfile knexfile.cjs",
    "seed": "knex seed:run --knexfile knexfile.cjs",
    "test": "jest --forceExit --detectOpenHandles",
    "security:audit": "npm audit --production",
    "security:check": "ts-node src/scripts/security-check.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.98.0",
    "@types/compression": "^1.8.1",
    "@types/nodemailer": "^7.0.11",
    "axios": "^1.7.9",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csv-parse": "^6.1.0",
    "dotenv": "^16.4.7",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "express-validator": "^7.2.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.2",
    "pg": "^8.13.1",
    "pg-connection-string": "^2.11.0",
    "puppeteer": "^23.11.1",
    "razorpay": "^2.9.5",
    "resend": "^6.9.3",
    "uuid": "^11.0.5",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.5",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "jest": "^30.2.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.3"
  },
  "optionalDependencies": {
    "@aws-sdk/client-s3": "^3.1016.0",
    "@aws-sdk/s3-request-presigner": "^3.1016.0"
  }
}
