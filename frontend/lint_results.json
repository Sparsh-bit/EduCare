                               onClick={() => hasChildren ? toggleMenu(item.label) : null}\n                                    className={`\n                                        w-full flex items-center gap-4 px-4 py-3.5 rounded-2xl transition-all duration-300 group\n                                        ${(active || anyChildActive) ? \"bg-[#003d73]/5 text-[#003d73]\" : \"text-gray-400 hover:bg-gray-50 hover:text-[#003d73]\"}\n                                    `}\n                                >\n                                    {hasChildren ? (\n                                        <>\n                                            <div className={`p-2 rounded-xl transition-all ${anyChildActive ? \"bg-white shadow-sm text-[#003d73]\" : \"group-hover:scale-110\"}`}>\n                                                <Icon size={18} strokeWidth={anyChildActive ? 2.5 : 2} />\n                                            </div>\n                                            <span className=\"flex-1 text-[13px] font-black uppercase tracking-widest text-left\">{item.label}</span>\n                                            <motion.div\n                                                animate={{ rotate: isOpen ? 180 : 0 }}\n                                                transition={{ duration: 0.3 }}\n                                            >\n                                                <ChevronDown size={14} className=\"opacity-40\" />\n                                            </motion.div>\n                                        </>\n                                    ) : (\n                                        <Link href={item.href!} className=\"flex items-center gap-4 w-full\">\n                                            <div className={`p-2 rounded-xl transition-all ${active ? \"bg-white shadow-sm text-[#003d73]\" : \"group-hover:scale-110\"}`}>\n                                                <Icon size={18} strokeWidth={active ? 2.5 : 2} /