Core\";\n        case \"accounts\": return \"Enterprise Ledger\";\n        case \"exams\": return \"Assessment Node\";\n        case \"front-desk\": return \"Front Desk\";\n        case \"hr\": return \"Human Capital\";\n        default:\n            return mapped\n                .split(\"-\")\n                .map((part) => part.charAt(0).toUpperCase() + part.slice(1))\n                .join(\" \");\n    }\n}\n\nfunction ProtectedContent({ children }: { children: React.ReactNode }) {\n    const { user, loading } = useAuth();\n    const router = useRouter();\n    const pathname = usePathname();\n\n    useEffect(() => {\n        if (!loading && !user) {\n            router.push(\"/login\");\n        }\n    }, [user, loading, router]);\n\n    const todayLabel = useMemo(\n        () =>\n            new Date().toLocaleDateString(\"en-IN\", {\n                weekday: \"long\",\n                day: \"2-digit\",\n                month: \"short\",\n                year: \"numeric\",\n            }),\n        []\n    );\n\n    const pageTitle = routeTitle(pathname);\n\n    if (loading) {\n        return (\n            <div className=\"flex min-h-screen items-center justify-center bg-white\">\n                <div className=\"flex flex-col items-center gap-6\">\n                    <div className=\"w-16 h-16 border-4 border-[#003d73]/10 border-t-[#003d73] rounded-full animate-spin\" />\n                    <p className=\"text-[10px] font-black uppercase tracking-[0.4em] text-gray-300\">Synchronizing Identity...</p>\n                </div>\n            </div>\n        );\n    }\n\n    if (!user) return null;\n\n    return (\n        <div className=\"dashboard-area relative min-h-screen bg-white\">\n            {/* Cinematic Background Elements */}\n            <div className=\"fixed inset-0 pointer-events-none z-0 overflow-hidden\">\n                <div className=\"absolute top-[-10%] right-[-10%] w-[50%] h-[50%] bg-[#84cc16]/5 rounded-full blur-[140px]\" />\n                <div className=\"absolute bottom-[-10%] left-[-10%] w-[40%] h-[40%] bg-[#003d73]/5 rounded-full blur-[140px]\" />\n                <div className=\"landing-grid-overlay opacity-5\" />\n            </div>\n\n            <div className=\"relative flex min-h-screen z-10\">\n                <Sidebar />\n\n                <div className=\"flex min-w-0 flex-1 flex-col\">\n                    <header className=\"sticky top-0 z-[60] bg-white/70 backdrop-blur-xl border-b border-gray-50 h-24 flex items-center\">\n                        <div className=\"w-full px-8 flex items-center justify-between\">\n                            <div className=\"flex items-center gap-6\">\n                                <div className=\"hidden lg:block\">\n                                    <p className=\"text-[10px] font-black uppercase tracking-[0.3em] text-[#84cc16] mb-1\">Authenticated Node</p>\n                                    <h1 className=\"text-3xl font-black tracking-tighter text-[#003d73] leading-none\">{pageTitle}</h1>\n                                </div>\n                            </div>\n\n                            <div className=\"flex items-center gap-4\">\n                                {/* Search Bar */}\n                                <div className=\"hidden md:flex items-center gap-3 bg-gray-50 px-4 h-12 rounded-2xl border border-transparent focus-within:border-[#003d73]/10 focus-within:bg-white transition-all w-80 group\">\n                                    <Search size={18} className=\"text-gray-300 group-focus-within:text-[#003d73]\" />\n                                    <input \n                                        type=\"text\" \n                                        placeholder=\"Search terminal protocols...\" \n                                        className=\"bg-transparent border-none outline-none text-sm font-bold text-[#003d73] placeholder:text-gray-300 w-full\"\n                                    />\n                                    <div className=\"flex items-center gap-1 border border-gray-200 rounded-lg px-2 py-0.5\">\n                                        <Command size={10} className=\"text-gray-400\" />\n                                        <span className=\"text-[9px] font-black text-gray-400\">K</span>\n                                    </div>\n                                </div>\n\n                                <div className=\"flex items-center gap-2\">\n                                    <button className=\"w-12 h-12 rounded-2xl border border-gray-100 flex items-center justify-center text-gray-400 hover:bg-gray-50 transition-all relative\">\n                                        <Bell size={20} />\n                                        <div className=\"absolute top-3 right-3 w-2 h-2 rounded-full bg-rose-500 ring-2 ring-white\" />\n                                    </button>\n                                    <div className=\"h-10 w-px bg-gray-100 mx-2 hidden sm:block\" />\n                                    <div className=\"hidden sm:flex items-center gap-3 px-4 h-12 rounded-2xl bg-[#003d73] text-white shadow-xl shadow-[#003d73]/20\">\n                                        <CalendarDays size={18} className=\"text-[#84cc16]\" />\n                                        <span className=\"text-[11px] font-black uppercase tracking-widest\">{todayLabel}</span>\n                                    </div>\n                                </div>\n                            </div>\n                        </div>\n                    </header>\n\n                    <main className=\"flex-1 p-8\">\n                        <div className=\"mx-auto w-full max-w-[1600px]\">\n                            {children}\n                        </div>\n                    </main>\n                </div>\n            </div>\n        </div>\n    );\n}\n\nexport default function DashboardLayout({ children }: { children: React.ReactNode }) {\n    return (\n        <AuthProvider>\n            <Toaster\n                position=\"top-right\"\n                toastOptions={{\n                    duration: 4000,\n                    style: {\n                        borderRadius: \"20px\",\n                        fontSize: \"12px\",\n                        fontWeight: \"900\",\n                        textTransform: \"uppercase\",\n                        letterSpacing: \"0.1em\",\n                        padding: \"16px 24px\",\n                        background: \"#003d73\",\n                        color: \"#ffffff\",\n                        border: \"1px solid rgba(132, 204, 22, 0.2)\",\n                    },\n                }}\n            />\n            <ProtectedContent>{children}</ProtectedContent>\n        </AuthProvider>\n    );\n}\n","usedDeprecatedRules":[]},{"filePath":"/Volumes/Volume D/Concilio_Claud/ndps-erp/frontend/src/app/(dashboard)/notices/page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Volumes/Volume D/Concilio_Claud/ndps-erp/frontend/src/app/(dashboard)/payments/advanced/page.tsx","messages":[{"ruleId":"@next/next/no-img-element","severity":1,"message":"Using `<img>` could result in slower LCP and higher bandwidth. Consider using `<Image />` from `next/image` or a custom image loader to automatically optimize images. This may incur additional usage or cost from your provider. See: https://nextjs.org/docs/messages/no-img-element","line":463,"column":19,"nodeType":"JSXOpeningElement","endLine":463,"endColumn":126}],"suppressedMessages":[{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":21,"column":65,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":21,"endColumn":68,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[867,870],"text":"unknown"},"desc":"Use `unknown` instead, this will forc