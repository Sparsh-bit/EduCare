# ════════════════════════════════════════════════════════════
# EduCare ERP Frontend — Production Environment Variables
# Set these in Vercel dashboard:
#   Project → Settings → Environment Variables
# On AWS: baked into the Docker image at build time via --build-arg
# ════════════════════════════════════════════════════════════

# URL of your deployed backend
# AWS ALB: https://api.your-school-domain.com/api
# Railway:  https://your-backend.railway.app/api
NEXT_PUBLIC_API_URL=https://api.your-school-domain.com/api

# Supabase (same project as backend)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Web3Forms (for the EduCare landing page contact form)
WEB3FORMS_ACCESS_KEY=your-web3forms-key
