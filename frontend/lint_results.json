dency array.","line":36,"column":8,"nodeType":"ArrayExpression","endLine":36,"endColumn":79,"suggestions":[{"desc":"Update the dependencies array to be: [fetchStudents, filters.class_id, filters.section_id, filters.status, pagination.page]","fix":{"range":[1356,1427],"text":"[fetchStudents, filters.class_id, filters.section_id, filters.status, pagination.page]"}}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":7,"fixableErrorCount":0,"fixableWarningCount":0,"source":"\"use client\";\n\nimport { useState, useEffect } from \"react\";\nimport Link from \"next/link\";\nimport { motion, AnimatePresence } from \"framer-motion\";\nimport { api, reportApiError } from \"@/lib/api\";\nimport type { Student, Class, Section } from \"@/lib/types\";\nimport { useAuth } from \"@/contexts/AuthContext\";\nimport { \n    Search, Filter, Plus, FileDown, MoreHorizontal, \n    User, Mail, Phone, Hash, ChevronLeft, ChevronRight,\n    Hexagon, Zap, GraduationCap\n} from \"lucide-react\";\n\nexport default function StudentsPage() {\n    const { user } = useAuth();\n    const isTeacher = user?.role === \"teacher\";\n    const [students, setStudents] = useState<Student[]>([]);\n    const [classes, setClasses] = useState<Class[]>([]);\n    const [sections, setSections] = useState<Section[]>([]);\n    const [loading, setLoading] = useState(true);\n    const [filters, setFilters] = useState({ class_id: \"\", section_id: \"\", status: \"active\", search: \"\" });\n    const [pagination, setPagination] = useState({ page: 1, limit: 20, total: 0 });\n\n    useEffect(() => { \n        api.getClasses().then(setClasses).catch(reportApiError); \n    }, []);\n\n    useEffect(() => {\n        if (filters.class_id) api.getSections(parseInt(filters.class_id)).then(setSections);\n        else setSections([]);\n    }, [filters.class_id]);\n\n    useEffect(() => { \n        fetchStudents(); \n    }, [filters.class_id, filters.section_id, filters.status, pagination.page]);\n\n    const fetchStudents = async () => {\n        setLoading(true);\n        try {\n            const params: Record<string, string | number> = { page: pagination.page, limit: pagination.limit };\n            if (filters.class_id) params.class_id = filters.class_id;\n            if (filters.section_id) params.section_id = filters.section_id;\n            if (filters.status) params.status = filters.status;\n            if (filters.search) params.search = filters.search;\n            const data = await api.getStudents(params);\n            setStudents(data.data);\n            setPagination((p) => ({ ...p, total: data.total || 0 }));\n        } catch (err) { \n            reportApiError(err); \n        } finally { \n            setLoading(false); \n        }\n    };\n\n    const handleSearch = (e: React.FormEvent) => { \n        e.preventDefault(); \n        setPagination((p) => ({ ...p, page: 1 })); \n        fetchStudents(); \n    };\n\n    return (\n        <div className=\"space-y-10 pb-20\">\n            {/* Header Section */}\n            <div className=\"flex flex-col lg:flex-row lg:items-end justify-between gap-8\">\n                <div>\n                    <div className=\"inline-flex items-center gap-2 px-3 py-1 rounded-full bg-[#003d73]/5 text-[#003d73] text-[9px] font-black uppercase tracking-widest mb-4\">\n                        <Hexagon size={12} className=\"text-[#84cc16]\" />\n                        Registry Access: Tier 1\n                    </div>\n                    <h1 className=\"text-4xl font-black text-[#003d73] tracking-tighter leading-none mb-3\">Student Directory</h1>\n                    <p className=\"text-sm font-bold text-gray-400\">Synchronized with {pagination.total} active academic nodes.</p>\n                </div>\n\n                {!isTeacher && (\n                    <div className=\"flex items-center gap-3\">\n                        <button className=\"h-12 px-6 rounded-2xl bg-white border border-gray-100 text-[10px] font-black uppercase tracking-widest text-[#003d73] hover:bg-gray-50 transition-all flex items-center gap-2 shadow-sm\">\n                            <FileDown size={16} />\n                            Export Dataset\n                        </button>\n                        <Link href=\"/students/new\" className=\"h-12 px-6 rounded-2xl bg-[#003d73] text-white text-[10px] font-black uppercase tracking-widest flex items-center gap-2 hover:scale-[1.02] active:scale-[0.98] transition-all shadow-xl shadow-[#003d73]/10\">\n                            <Plus size={16} className=\"text-[#84cc16]\" />\n                            Provision Student\n                        </Link>\n                    </div>\n                )}\n            </div>\n\n            {/* Premium Filter Controls */}\n            <section className=\"premium-panel p-8 bg-gray-50/50\">\n                <form onSubmit={handleSearch} className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-6 items-end\">\n                    <div className=\"lg:col-span-3 space-y-2\">\n                        <label className=\"text-[10px] font-black uppercase tracking-widest text-gray-400 pl-1\">Academic Level</label>\n                        <select\n                            value={filters.class_id}\n                            onChange={(e) => setFilters({ ...filters, class_id: e.target.value, section_id: \"\" })}\n                            className=\"w-full h-12 bg-white border-transparent rounded-xl text-xs font-bold text-[#003d73] px-4 focus:ring-4 focus:ring-[#003d73]/5 outline-none transition-all shadow-sm\"\n                        >\n                            <option value=\"\">All Standards</option>\n                            {classes.map((c) => (\n                                <option key={c.id} value={c.id}>\n                                    {String(c.name || \"\").toLowerCase().startsWith(\"class\") ? c.name : \"Class \" + c.name}\n                                </option>\n                            ))}\n                        </select>\n                    </div>\n\n                    <div className=\"lg:col-span-2 space-y-2\">\n                        <label className=\"text-[10px] font-black uppercase tracking-widest text-gray-400 pl-1\">Section Branch</label>\n                        <select\n                            value={filters.section_id}\n                            onChange={(e) => setFilters({ ...filters, section_id: e.target.value })}\n                            disabled={!filters.class_id}\n                            className=\"w-full h-12 bg-white border-transparent rounded-xl text-xs font-bold text-[#003d73] px-4 focus:ring-4 focus:ring-[#003d73]/5 outline-none transition-all shadow-sm disabled:opacity-40\"\n                        >\n                            <option value=\"\">All Sections</option>\n                            {sections.map((s) => <option key={s.id} value={s.id}>{s.name}</option>)}\n                        </select>\n                    </div>\n\n                    <div className=\"lg:col-span-2 space-y-2\">\n                        <label className=\"text-[10px] font-black uppercase tracking-widest text-gray-400 pl-1\">Node Status</label>\n                        <select\n                            value={filters.status}\n                            onChange={(e) => setFilters({ ...filters, status: e.target.value })}\n                            className=\"w-full h-12 bg-white border-transparent rounded-xl text-xs font-bold text-[#003d73] px-4 focus:ring-4 focus:ring-[#003d73]/5 outline-none transition-all shadow-sm\"\n                        >\n                            <option value=\"active\">Active</option>\n                            <option value=\"alumni\">Archived</option>\n                            <option value=\"tc_issued\">Deactivated</option>\n                            <option value=\"\">Global Search</option>\n                        </select>\n                    </div>\n\n                    <div className=\"lg:col-span-5 space-y-2\">\n                        <label className=\"text-[10px] font-black uppercase tracking-widest text-gray-400 pl-1\">Search Registry</label>\n                        <div className=\"relative group\">\n                            <Search size={16} className=\"absolute left-4 top-1/2 -translate-y-1/2 text-gray-300 group-focus-within:text-[#003d73] transition-colors\" />\n                            <input\n                                type=\"text\"\n                                placeholder=\"Identifier, Name, or Mobile...\"\n                                value={filters.search}\n                                onChange={(e) => setFilters({ ...filters, search: e.target.value })}\n                                className=\"w-full h-12 pl-12 pr-4 bg-white border-transparent rounded-xl text-xs font-bold text-[#003d73] focus:ring-4 focus:ring-[#003d73]/5 outline-none transition-all shadow-sm\"\n                            />\n                        </div>\n                    </div>\n                </form>\n            </section>\n\n            {/* Data Table Section */}\n            <div className=\"premium-panel border-gray-100 overflow-hidden bg-white\">\n                <div className=\"overflow-x-auto\">\n                    {loading ? (\n                        <div className=\"py-32 text-center space-y-4\">\n                            <div className=\"w-12 h-12 border-4 border-[#003d73]/5 border-t-[#003d73] rounded-full animate-spin mx-auto\" />\n                            <p className=\"text-[10px] font-black uppercase tracking-[0.4em] text-gray-300\">Scanning Registry...</p>\n                        </div>\n                    ) : students.length === 0 ? (\n                        <div className=\"py-32 text-center flex flex-col items-center gap-6\">\n                            <div className=\"w-20 h-20 bg-gray-50 rounded-3xl flex items-center justify-center text-gray-200\">\n                                <Search size={40} />\n                            </div>\n                            <div>\n                                <h3 className=\"text-xl font-black text-[#003d73] tracking-tighter\">No Units Detected</h3>\n                                <p className=\"text-sm font-bold text-gray-400 mt-1\">Adjust filters to re-scan the academic network.</p>\n                            </div>\n                        </div>\n                    ) : (\n                        <table className=\"w-full text-left border-collapse\">\n                            <thead>\n                                <tr className=\"border-b border-gray-50 bg-gray-50/30\">\n                                    <th className=\"px-8 py-5 text-[10px] font-black uppercase tracking-[0.2em] text-gray-400\">Node Principal</th>\n                                    <th className=\"px-8 py-5 text-[10px] font-black uppercase tracking-[0.2em] text-gray-400\">Hierarchy</th>\n                                    <th className=\"px-8 py-5 text-[10px] font-black uppercase tracking-[0.2em] text-gray-400\">Metadata</th>\n                                    <th className=\"px-8 py-5 text-[10px] font-black uppercase tracking-[0.2em] text-gray-400 text-center\">Protocol Status</th>\n                                    {!isTeacher && <th className=\"px-8 py-5 text-right text-[10px] font-black uppercase tracking-[0.2em] text-gray-400\">Control</th>}\n                                </tr>\n                            </thead>\n                            <tbody className=\"divide-y divide-gray-50/50\">\n                                {students.map((student) => (\n                                    <tr key={student.id} className=\"group hover:bg-[#003d73]/5 transition-all duration-300\">\n                                        <td className=\"px-8 py-6\">\n                                            <div className=\"flex items-center gap-4\">\n                                                <div className=\"w-12 h-12 rounded-2xl bg-gray-50 border border-gray-100 text-[#003d73] flex items-center justify-center font-black text-sm group-hover:bg-[#003d73] group-hover:text-white transition-all\">\n                                                    {student.name.charAt(0)}\n                                                </div>\n                                                <div>\n                                                    <p className=\"font-black text-[#003d73] text-sm tracking-tight\">{student.name}</p>\n                                                    <div className=\"flex items-center gap-2 mt-1\">\n                                                        <Hash size={10} className=\"text-[#84cc16]\" />\n                                                        <span className=\"text-[10px] font-bold text-gray-400\">ADM: {student.admission_no}</span>\n                                                    </div>\n                                                </div>\n                                            </div>\n                                        </td>\n                                        <td className=\"px-8 py-6\">\n                                            <div className=\"flex flex-col\">\n                                                <span className=\"text-sm font-black text-[#003d73] tracking-tight\">\n                                                    {String(student.class_name || \"\").toLowerCase().startsWith(\"class\") ? student.class_name : \"Class \" + student.class_name}\n                                                </span>\n                                                <span className=\"text-[10px] font-bold text-gray-300 uppercase tracking-widest mt-0.5\">{student.section_name || \"General Node\"}</span>\n                                            </div>\n                                        </td>\n                                        <td className=\"px-8 py-6\">\n                                            <div className=\"flex flex-col gap-1\">\n                                                <div className=\"flex items-center gap-2 text-[11px] font-bold text-gray-500\">\n                                                    <User size={12} className=\"text-[#003d73]/30\" />\n                                                    {student.father_name || \"N/A\"}\n                                                </div>\n                                                <div className=\"flex items-center gap-2 text-[11px] font-bold text-gray-500\">\n                                                    <Zap size={12} className=\"text-[#84cc16]/50\" />\n                                                    Roll: {student.current_roll_no || \"—\"}\n                                                </div>\n                                            </div>\n                                        </td>\n                                        <td className=\"px-8 py-6\">\n                                            <div className=\"flex justify-center\">\n                                                <span className={`\n                                                    inline-flex items-center px-4 py-1 rounded-full text-[9px] font-black uppercase tracking-widest\n                                                    ${student.status === \"active\" ? \"bg-emerald-50 text-emerald-600 border border-emerald-100\" :\n                                                      student.status === \"tc_issued\" ? \"bg-rose-50 text-rose-600 border border-rose-100\" : \n                                                      \"bg-amber-50 text-amber-600 border border-amber-100\"}\n                                                `}>\n                                                    {student.status === \"active\" ? \"Synced\" : student.status}\n                                                </span>\n                                            </div>\n                                        </td>\n  