nge":[32134,32137],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"\"use client\";\n\nimport { useState } from 'react';\nimport { useRouter } from 'next/navigation';\nimport Link from 'next/link';\nimport { motion, AnimatePresence } from 'framer-motion';\nimport { API_BASE } from '@/lib/runtimeConfig';\nimport { \n  Building2, \n  User, \n  Mail, \n  Lock, \n  Phone, \n  MapPin, \n  ShieldCheck, \n  ArrowRight, \n  ChevronRight,\n  Sparkles,\n  BookOpen,\n  LayoutGrid,\n  ClipboardCheck,\n  Check\n} from 'lucide-react';\n\nconst BOARDS = ['CBSE', 'ICSE', 'State Board', 'IB', 'IGCSE', 'Others'];\nconst SECTION_LETTERS = ['A', 'B', 'C', 'D', 'E', 'F', 'G', 'H'];\n\ninterface FormData {\n    schoolName: string; ownerName: string; email: string; password: string;\n    phone: string; address: string; board: string;\n    includePrePrimary: boolean; numClasses: number; sectionsPerClass: number;\n}\n\nexport default function SignUpPage() {\n    const router = useRouter();\n    const [step, setStep] = useState(1);\n    const [form, setForm] = useState<FormData>({\n        schoolName: '', ownerName: '', email: '', password: '', phone: '', address: '',\n        board: 'CBSE', includePrePrimary: false, numClasses: 10, sectionsPerClass: 2,\n    });\n    const [showPass, setShowPass] = useState(false);\n    const [error, setError] = useState('');\n    const [loading, setLoading] = useState(false);\n    const [success, setSuccess] = useState(false);\n    const [schoolCode, setSchoolCode] = useState('');\n    const [copied, setCopied] = useState(false);\n\n    const set = (key: keyof FormData, value: string | number | boolean) =>\n        setForm(f => ({ ...f, [key]: value }));\n\n    const classPreview: string[] = [];\n    if (form.includePrePrimary) classPreview.push('Nursery', 'LKG', 'UKG');\n    for (let i = 1; i <= form.numClasses; i++) classPreview.push(`Class ${i}`);\n    const sectionPreview = SECTION_LETTERS.slice(0, form.sectionsPerClass);\n\n    const step1Valid = form.schoolName && form.ownerName && form.email && form.password.length >= 8;\n\n    const handleSubmit = async () => {\n        setError('');\n        setLoading(true);\n        try {\n            const res = await fetch(`${API_BASE}/auth/register-school`, {\n                method: 'POST',\n                headers: { 'Content-Type': 'application/json' },\n                body: JSON.stringify({\n                    schoolName: form.schoolName, ownerName: form.ownerName,\n                    email: form.email, password: form.password,\n                    phone: form.phone || undefined, address: form.address || undefined,\n                    board: form.board, includePrePrimary: form.includePrePrimary,\n                    numClasses: form.numClasses, sectionsPerClass: form.sectionsPerClass,\n                }),\n            });\n            const data = await res.json();\n            if (!res.ok) throw new Error(data.error || 'Registration failed');\n            setSchoolCode(data.schoolCode);\n            setSuccess(true);\n        } catch (err: unknown) {\n            setError(err instanceof Error ? err.message : 'Registration failed');\n        } finally {\n            setLoading(false);\n        }\n    };\n\n    return (\n        <div className=\"min-h-screen bg-white flex overflow-hidden relative\">\n            {/* Background elements */}\n            <div className=\"absolute inset-0 z-0 pointer-events-none\">\n                <div className=\"absolute top-[-5%] left-[-5%] w-[30%] h-[30%] bg-[#003d73]/5 rounded-full blur-[100px]\" />\n                <div className=\"absolute bottom-[0%] right-[-5%] w-[40%] h-[40%] bg-[#84cc16]/10 rounded-full blur-[120px]\" />\n                <div className=\"landing-grid-overlay opacity-5\" />\n            </div>\n\n            {/* Main Content */}\n            <div className=\"flex-1 flex flex-col relative z-10 w-full\">\n                {/* Header */}\n                <div className=\"w-full h-24 px-8 flex items-center justify-between border-b border-gray-50\">\n                    <Link href=\"/\" className=\"flex items-center gap-3\">\n                        <div className=\"w-10 h-10 bg-[#003d73] rounded-xl flex items-center justify-center shadow-lg\">\n                            <span className=\"text-white font-black text-xl tracking-tighter\">E</span>\n                        </div>\n                        <span className=\"font-black text-xl tracking-tighter text-[#003d73]\">EduCare</span>\n                    </Link>\n                    \n                    <div className=\"hidden sm:flex items-center gap-4\">\n                        {[\n                            { step: 1, label: \"Identity\" },\n                            { step: 2, label: \"Structure\" },\n                            { step: 3, label: \"Genesis\" }\n                        ].map((s, i) => (\n                            <div key={i} className=\"flex items-center gap-3\">\n                                <div className={`h-8 px-4 rounded-full flex items-center justify-center text-[10px] font-black uppercase tracking-widest transition-all ${step === s.step ? 'bg-[#003d73] text-white shadow-lg shadow-blue-900/10' : 'bg-gray-100/50 text-gray-300'}`}>\n                                    {s.label}\n                                </div>\n                                {i < 2 && <ChevronRight size={14} className=\"text-gray-200\" />}\n                            </div>\n                        ))}\n                    </div>\n\n                    <Link href=\"/login\" className=\"text-xs font-black uppercase tracking-widest text-gray-400 hover:text-[#003d73] transition-colors\">SignIn</Link>\n                </div>\n\n                <div className=\"flex-1 overflow-y-auto px-6 py-12 flex justify-center custom-scrollbar\">\n                    <div className=\"w-full max-w-2xl\">\n                        <AnimatePresence mode=\"wait\">\n                            {success ? (\n                                <motion.div \n                                    key=\"success\"\n                                    initial={{ opacity: 0, scale: 0.9, y: 30 }}\n                                    animate={{ opacity: 1, scale: 1, y: 0 }}\n                                    className=\"pt-10 text-center\"\n                                >\n                                    <div className=\"w-24 h-24 bg-[#84cc16]/10 rounded-[2.5rem] flex items-center justify-center text-[#84cc16] mx-auto mb-10 shadow-2xl\">\n                                        <Sparkles size={48} />\n                                    </div>\n                                    <h2 className=\"text-5xl font-black text-[#003d73] mb-6 tracking-tighter\">Registration Complete.</h2>\n                                    <p className=\"text-lg text-gray-400 font-bold mb-12 max-w-md mx-auto\">\n                                        The enterprise node for <span className=\"text-[#003d73]\">{form.schoolName}</span> has been provisioned.\n                                    </p>\n\n                                    <div className=\"premium-panel p-10 max-w-sm mx-auto mb-12 border-white shadow-2xl\">\n                                        <p className=\"text-[10px] font-black uppercase tracking-[0.3em] text-gray-300 mb-6\">Generated Access Key</p>\n                                        <div className=\"flex items-center justify-center gap-4 mb-8\">\n                                            <span className=\"text-4xl font-black tracking-[0.2em] text-[#003d73] font-mono\">{schoolCode}</span>\n                                            <button\n                                                onClick={() => { \n                                                    navigator.clipboard.writeText(schoolCode); \n                                                    setCopied(true); \n                                                    setTimeout(() => setCopied(false), 2000); \n                                                }}\n                                                className={`p-3 rounded-xl transition-all ${copied ? 'bg-emerald-50 text-emerald-500' : 'bg-gray-50 text-gray-400 hover:bg-[#003d73]/5 hover:text-[#003d73]'}`}\n                                            >\n                                                {copied ? <Check size={20} /> : <ClipboardCheck size={20} />}\n                                            </button>\n                                        </div>\n                                        <div className=\"space-y-3\">\n                                            <div className=\"flex justify-between items-center px-4 py-3 bg-gray-50/50 rounded-xl\">\n                                                <span className=\"text-[10px] font-black text-gray-300 uppercase tracking-widest\">Master User</span>\n                                                <span className=\"text-xs font-black text-[#003d73]\">{form.email}</span>\n                                            </div>\n                                            <div className=\"flex justify-between items-center px-4 py-3 bg-gray-50/50 rounded-xl\">\n                                                <span className=\"text-[10px] font-black text-gray-300 uppercase tracking-widest\">Status</span>\n                                                <span className=\"flex items-center gap-2 text-[10px] font-black text-[#84cc16] uppercase tracking-widest\">\n                                                    <div className=\"w-1.5 h-1.5 rounded-full bg-[#84cc16] animate-pulse\" />\n                                                    Active\n                                                </span>\n                                            </div>\n                                        </div>\n                                    </div>\n\n                                    <Link\n                                        href={`/login?schoolCode=${encodeURIComponent(schoolCode)}&username=${encodeURIComponent(form.email)}`}\n                                        className=\"premium-button inline-flex h-16 px-12 items-center justify-center bg-[#003d73] text-white text-xs font-black uppercase tracking-[0.3em] rounded-2xl shadow-2xl glow-heavy transition-all hover:scale-[1.02] active:scale-[0.98]\"\n                                    >\n                                        Enter Terminal\n                                        <ArrowRight size={20} className=\"ml-4\" />\n                                    </Link>\n                                </motion.div>\n                            ) : (\n                                <motion.div \n                                    key={`step-${step}`}\n                                    initial={{ opacity: 0, x: 20 }}\n                                    animate={{ opacity: 1, x: 0 }}\n                                    exit={{ opacity: 0, x: -20 }}\n                                    transition={{ duration: 0.5, ease: \"easeOut\" }}\n                                    className=\"space-y-10\"\n                                >\n                                    <div className=\"mb-12\">\n                                        <h2 className=\"text-5xl font-black text-[#003d73] tracking-tighter mb-4 leading-none\">\n                                            {step === 1 ? \"Organization Identity.\" : step === 2 ? \"Infrastructure Build.\" : \"Genesis Protocol.\"}\n                                        </h2>\n                                        <p className=\"text-lg text-gray-400 font-bold tracking-tight\">\n                                            {step === 1 ? \"Define the primary credentials for your institution.\" : step === 2 ? \"Configure the internal academic architecture of the node.\" : \"Verify all deployment protocols before initialization.\"}\n                                        </p>\n                                    </div>\n\n                                    {error && (\n                                        <div className=\"p-4 bg-red-50 border border-red-100 rounded-2xl flex items-center gap-3\">\n                                            <div className=\"w-2 h-2 rounded-full bg-red-500 animate-pulse\" />\n                                            <span className=\"text-red-600 text-[10px] font-black uppercase tracking-widest\">{error}</span>\n                                        </div>\n                                    )}\n\n                                    {/* ── STEP 1: Identification ── */}\n                                    {step === 1 && (\n                                        <div className=\"space-y-8\">\n                                            <div className=\"grid grid-cols-1 md:grid-cols-2 gap-8\">\n                                                <AuthField icon={<Building2 size={18}/>} label=\"School Name\" value={form.schoolName} onChange={v => set('schoolName', v)} placeholder=\"e.g. Royal Academy\" />\n                                                <AuthField icon={<User size={18}/>} label=\"Primary Representative\" value={form.ownerName} onChange={v => set('ownerName', v)} placeholder=\"Principal / Owner Name\" />\n                                                <AuthField icon={<Mail size={18}/>} label=\"Corporate Email\" type=\"email\" value={form.email} onChange={v => set('email', v)} placeholder=\"admin@school.com\" />\n                                                <AuthField icon={<Phone size={18}/>} label=\"Node Hotline\" type=\"tel\" value={form.phone} onChange={v => set('phone', v)} placeholder=\"+91 XXXX-XXXXXX\" />\n                                            </div>\n                                            \n                                            <div className=\"relative group\">\n                                                <AuthField \n                                                    icon={<Lock size={18}/>} \n                                                    label=\"Master Access Key\" \n                                                    type={showPass ? 'text' : 'password'} \n                                                    value={form.password} \n                                                    onChange={v => set('password', v)} \n                                                    placeholder=\"••••••••\" \n                                                />\n                                                <button \n                                                    type=\"button\" \n                                                    onClick={() => setShowPass(!showPass)}\n                                                    className=\"absolute right-6 bottom-5 text-[#003d73]/20 hover:text-[#003d73] text-[10px] font-black uppercase tracking-widest transition-colors\"\n                                                >\n                                                    {showPass ? 'Conceal' : 'Reveal'}\n                                                </button>\n                                            </div>\n\n                                            <div className=\"space-y-2\">\n                                                <label className=\"text-[10px] font-black uppercase tracking-widest text-gray-400 pl-2 flex items-center gap-2\">\n                                                     <MapPin size={12} />\n                                                     Geographical Coordinates (Address)\n                                                </label>\n                                                <textarea \n                                                    value={form.address} \n                                                    onChange={e => set('address', e.target.value)} \n                                                    rows={3}\n                                                    placeholder=\"Specify physical location of the campus...\"\n                                                    className=\"w-full p-6 h-32 rounded-2xl bg-gray-50/50 border border-transparent focus:bg-white focus:border-[#003d73]/20 transition-all text-sm font-bold text-[#003d73] outline-none placeholder:text-gray-300 resize-none\"\n                                                />\n                                            </div>\n\n                                            <button\n                                                onClick={() => {\n                                                    if (step1Valid) { setError(''); setStep(2); }\n                                                    else setError('Validation failed. Ensure all master fields are populated (password ≥ 8).');\n                                                }}\n                                                className=\"premium-button w-full h-16 bg-[#003d73] text-white text-xs font-black uppercase tracking-[0.3em] rounded-2xl shadow-xl active:scale-[0.98] transition-all flex items-center justify-center gap-4\"\n                                            >\n                                                Initialize Node Build\n                                                <ArrowRight size={20} />\n                                            </button>\n                                        </div>\n                                    )}\n\n                                    {/* ── STEP 2: Architecture ── */}\n                                    {step === 2 && (\n                                        <div className=\"space-y-12\">\n                                            <div className=\"space-y-6\">\n                                                <label className=\"text-[10px] font-black uppercase tracking-widest text-gray-300 flex items-center gap-3\">\n                                                    <BookOpen size={16} />\n                                                    Regulatory Board selection\n                                                </label>\n                                                <div className=\"grid grid-cols-2 sm:grid-cols-3 gap-4\">\n                                                    {BOARDS.map(b => (\n                                                        <button \n                                                            key={b} \n                                                            type=\"button\" \n                                                            onClick={() => set('board', b)}\n                                                            className={`h-14 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all border ${form.board === b ? 'bg-[#003d73] text-white border-transparent shadow-xl shadow-blue-900/10' : 'bg-gray-50/50 text-gray-400 border-gray-100 hover:border-[#003d73]/10'}`}\n                                                        >\n                                                            {b}\n                                                        </button>\n                                                    ))}\n                                                </div>\n                                            </div>\n\n                                            <div className=\"premium-panel p-8 bg-gray-50/20 flex items-center justify-between border-gray-100\">\n                                                <div className=\"flex items-center gap-5\">\n                                                    <div className=\"w-14 h-14 bg-white rounded-2xl flex items-center justify-center text-[#003d73] shadow-sm\">\n                                                        <LayoutGrid size={24} />\n                                                    </div>\n                                                    <div>\n                                                        <p className=\"text-xs font-black text-[#003d73] uppercase tracking-widest mb-1\">Pre-Primary Grid</p>\n                                                        <p className=\"text-[10px] font-bold text-gray-400 uppercase tracking-widest\">Nursery, LKG, UKG Nodes</p>\n                                                    </div>\n                                                </div>\n                                                <button \n                                                    type=\"button\" \n                                                    onClick={() => set('includePrePrimary', !form.includePrePrimary)}\n                                                    className={`relative w-16 h-8 rounded-full transition-all ${form.includePrePrimary ? 'bg-[#84cc16]' : 'bg-gray-200'}`}\n                                                >\n                                                    <div className={`absolute top-1 w-6 h-6 rounded-full bg-white shadow-lg transition-transform ${form.includePrePrimary ? 'translate-x-9' : 'translate-x-1'}`} />\n                                                </button>\n                                            </div>\n\n                                            <div className=\"space-y-8\">\n                                                <div className=\"flex items-center justify-between px-2\">\n                                                    <label className=\"text-[10px] font-black uppercase tracking-widest text-gray-300\">Standard Node Array (Classes)</label>\n                                                    <span className=\"text-2xl font-black text-[#003d73] tracking-tighter\">01 — {form.numClasses.toString().padStart(2, '0')}</span>\n                                                </div>\n                                                <div className=\"px-4\">\n                                                     <input \n                                                        type=\"range\" \n                                                        min={1} \n                                                        max={12} \n                                                        value={form.numClasses}\n                                                        onChange={e => set('numClasses', parseInt(e.target.value))}\n                                                        className=\"w-full h-1.5 bg-gray-100 rounded-lg appearance-none cursor-pointer accent-[#003d73]\" \n                                                    />\n                                                </div>\n                                            </div>\n\n                                            <div className=\"space-y-6\">\n                                                <label className=\"text-[10px] font-black uppercase tracking-widest text-gray-300\">Section Sub-Nodes</label>\n                                                <div className=\"flex flex-wrap gap-4\">\n                                                    {[1, 2, 3, 4, 5, 6].map(n => (\n                                                        <button \n                                                            key={n} \n                                                            type=\"button\" \n                                                            onClick={() => set('sectionsPerClass', n)}\n                                                            className={`w-14 h-14 rounded-xl text-sm font-black transition-all border ${form.sectionsPerClass === n ? 'bg-[#003d73] text-white border-transparent shadow-xl shadow-blue-900/10' : 'bg-gray-50/50 text-gray-400 border-gray-100'}`}\n                                                        >\n                                                            {n}\n                                                        </button>\n                                                    ))}\n                                                </div>\n                                                <p className=\"text-[10px] font-black text-[#003d73] uppercase tracking-[0.2em]\">Sections: {SECTION_LETTERS.slice(0, form.sectionsPerClass).join(' • ')}</p>\n                                            </div>\n\n                                            <div className=\"flex gap-6 pt-6\">\n                                                <button onClick={() => setStep(1)} className=\"flex-1 h-16 rounded-2xl text-[10px] font-black uppercase tracking-widest text-gray-300 hover:text-[#003d73] border border-gray-100 transition-all\">\n                                                    Abort & Return\n                                                </button>\n                                                <button onClick={() => { setError(''); setStep(3); }} className=\"premium-button flex-[2] h-16 bg-[#003d73] text-white text-[10px] font-black uppercase tracking-[0.2em] rounded-2xl shadow-xl\">\n                                                    Final Integrity Check\n                                                </button>\n                                            </div>\n                                        </div>\n                                    )}\n\n                                    {/* ── STEP 3: Review ── */}\n                                    {step === 3 && (\n                                        <div className=\"space-y-10\">\n                                            <div className=\"grid grid-cols-1 md:grid-cols-2 gap-6\">\n                                                <div className=\"premium-panel p-8 border-gray-100 shadow-sm bg-gray-50/5 hover:bg-white transition-all\">\n                                                    <p className=\"text-[10px] font-black uppercase tracking-widest text-gray-300 mb-6\">Identity Specs</p>\n                                                    <div className=\"space-y-3\">\n                                                        <ReviewSpec label=\"Institution\" val={form.schoolName} />\n                                                        <ReviewSpec label=\"Master User\" val={form.ownerName} />\n                                                        <ReviewSpec label=\"Node Board\" val={form.board} />\n                                                        <ReviewSpec label=\"Auth Node\" val={form.email} />\n                                                    </div>\n                                                </div>\n\n                                                <div className=\"premium-panel p-8 border-gray-100 shadow-sm bg-gray-50/5 hover:bg-white transition-all\">\n                                                    <p className=\"text-[10px] font-black uppercase tracking-widest text-gray-300 mb-6\">Structural Specs</p>\n                                                    <div className=\"space-y-3 text-sm\">\n                                                        <ReviewSpec label=\"Total Nodes\" val={classPreview.length} color=\"text-[#003d73]\" />\n                                                        <ReviewSpec label=\"Sub-Nodes\" val={sectionPreview.length + \" / Class\"} color=\"text-[#003d73]\" />\n                                                        <ReviewSpec label=\"Total Capacity\" val={classPreview.length * sectionPreview.length + \" Units\"} color=\"text-[#84cc16]\" />\n                                                    </div>\n                                                </div>\n                                            </div>\n\n                                            <div className=\"flex items-center gap-4 p-6 bg-[#84cc16]/5 rounded-2xl border border-[#84cc16]/10\">\n                                                 <div className=\"w-10 h-10 rounded-full bg-[#84cc16]/10 flex items-center justify-center text-[#84cc16]\">\n                                                    <ShieldCheck size={24} />\n                                                 </div>\n                                                 <p className=\"text-xs font-bold text-gray-400 leading-relaxed\">\n                                                     By initializing, you agree to the <span className=\"text-[#003d73]\">Concilio Enterprise Protocols</span>. The master access key will be encrypted and stored in your primary node.\n                                                 </p>\n                                            </div>\n\n                                            <div className=\"flex gap-6\">\n                                                <button onClick={() => setStep(2)} className=\"flex-1 h-16 rounded-2xl text-[10px] font-black uppercase tracking-widest text-gray-300 border border-gray-100 hover:text-[#003d73] transition-all\">\n                                                    Architecture Edit\n                                                </button>\n                                                <button \n                                                    onClick={handleSubmit} \n                                                    disabled={loading}\n                                                    className=\"premium-button flex-[2] h-16 bg-[#003d73] text-white text-[10px] font-black uppercase tracking-[0.2em] rounded-2xl shadow-2xl glow-heavy\"\n                                                >\n                                                    {loading ? 'DEPLOYING NODE…' : 'INITIALIZE GENESIS PROTOCOL'}\n                                                </button>\n                                            </div>\n                                        </div>\n                                    )}\n                                </motion.div>\n                            )}\n                        </AnimatePresence>\n                    </div>\n                </div>\n            </div>\n            \n            {/* Visual Sidebar */}\n            <div className=\"hidden xl:flex w-[400px] bg-[#003d73] p-12 flex-col justify-between relative overflow-hidden\">\n                <div className=\"absolute inset-0 z-0\">\n                    <div className=\"absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-blue-500/10 rounded-full blur-[100px]\" />\n                    <div className=\"landing-grid-overlay opacity-20\" />\n                </div>\n                \n                <div className=\"relative z-10\">\n                    <div className=\"w-16 h-16 bg-white/10 backdrop-blur-xl rounded-[1.5rem] flex items-center justify-center text-[#84cc16] mb-12 border border-white/10 shadow-2xl\">\n                         <Sparkles size={32} />\n                    </div>\n                    <h3 className=\"text-4xl font-black text-white leading-tight tracking-tighter mb-8\">Deploying <br /> the Future.</h3>\n                    <p className=\"text-lg text-blue-100/50 font-bold mb-12\">Your institution is about to become a high-speed data ecosystem. Real-time analytics, automated recovery, and neural education pathways.</p>\n                </div>\n                \n                <div className=\"relative z-10 space-y-6\">\n                     {[\n                        { t: \"Uptime Node\", v: \"100ms Ping\" },\n                        { t: \"Deployment\", v: \"Instant\" },\n                        { t: \"Support\", v: \"Enterprise\" }\n                     ].map((it, i) => (\n                        <div key={i} className=\"flex justify-between items-center py-4 border-b border-white/5\">\n                            <span className=\"text-[10px] font-black text-white/30 uppercase tracking-widest\">{it.t}</span>\n                            <span className=\"text-[10px] font-black text-[#84cc16] uppercase tracking-[0.2em]\">{it.v}</span>\n                        </div>\n                     ))}\n                </div>\n            </div>\n        </div>\n    );\n}\n\nfunction AuthField({ icon, label, value, onChange, type = 'text', placeholder = '' }: {\n    icon: React.ReactNode; label: string; value: string; onChange: (v: string) => void;\n    type?: string; placeholder?: string;\n}) {\n    return (\n        <div className=\"space-y-2\">\n            <label className=\"text-[10px] font-black uppercase tracking-widest text-gray-400 pl-2\">{label}</label>\n            <div className=\"relative group\">\n                <div className=\"absolute left-6 top-1/2 -translate-y-1/2 text-gray-300 group-focus-within:text-[#003d73] transition-colors\">{icon}</div>\n                <input \n                    type={type} \n                    value={value} \n                    onChange={e => onChange(e.target.value)} \n                    placeholder={placeholder}\n                    className=\"w-full h-16 pl-14 pr-6 rounded-2xl bg-gray-50/50 border border-transparent focus:bg-white focus:border-[#003d73]/10 focus:ring-4 focus:ring-[#003d73]/5 outline-none transition-all text-sm font-bold text-[#003d73] placeholder:text-gray-300\"\n                />\n            </div>\n        </div>\n    );\n}\n\nfunction ReviewSpec({ label, val, color = \"text-gray-400\" }: { label: string; val: any; color?: string }) {\n    return (\n        <div className=\"flex justify-between items-center py-1\">\n            <span className=\"text-[10px] font-black uppercase tracking-widest text-gray-300\">{label}</span>\n            <span className={`text-xs font-black uppercase tracking-widest ${color}`}>{val}</span>\n        </div>\n    );\n}\n","usedDeprecatedRules":[]},{"filePath":"/Volumes/Volume D/Concilio_Claud/ndps-erp/frontend/src/app/verify-email/page.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'Mail' is defined but never used.","line":8,"column":10,"nodeType":"Identifier","messageId":"unusedVar","endLine":8,"endColumn":14,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"Mail"},"fix":{"range":[242,247],"text":""},"desc":"Remove unused variable \"Mail\"."}]},{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"React Hook useEffect has a missing dependency: 'sendOtp'. Either include it or remove the dependency array.","line":22,"column":8,"nodeType":"ArrayExpression","endLine":22,"endColumn":10,"suggestions":[{"desc":"Update the dependencies array to be: [sendOtp]","fix":{"range":[833,835],"text":"[sendOtp]"}}]},{"ruleId":"react/no-unescaped-entities","severity":2,"message":"`'` can be escaped with `&apos;`, `&lsquo;`, `&#39;`, `&rsquo;`.","line":187,"column":123,"nodeType":"JSXText","messageId":"unescapedEntityAlts","suggestions":[{"messageId":"replaceWithAlt","data":{"alt":"&apos;"},"fix":{"range":[9971,10003],"text":"Didn&apos;t receive the transmission?"},"desc":"Replace with `&apos;`."},{"messageId":"replaceWithAlt","data":{"alt":"&lsquo;"},"fix":{"range":[9971,10003],"text":"Didn&lsquo;t receive the transmission?"},"desc":"Replace with `&lsquo;`."},{"messageId":"replaceWithAlt","data":{"alt":"&#39;"},"fix":{"range":[9971,10003],"text":"Didn&#39;t receive the transmission?"},"desc":"Replace with `&#39;`."},{"messageId":"replaceWithAlt","data":{"alt":"&rsquo;"},"fix":{"range":[9971,10003],"text":"Didn&rsquo;t receive the transmission?"},"desc":"Replace with `&rsquo;`."}]}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":0,"source":"\"use client\";\n\nimport { useState, useEffect, useRef } from \"react\";\nimport { useRouter } from \"next/navigation\";\nimport Link from \"next/link\";\nimport { motion, AnimatePresence } from \"framer-motion\";\nimport { api } from \"@/lib/api\";\nimport { Mail, Check, Sparkles, ShieldCheck, RefreshCcw, ArrowRight } from \"lucide-react\";\n\nexport default function VerifyEmailPage() {\n    const router = useRouter();\n    const [otp, setOtp] = useState([\"\", \"\", \"\", \"\", \"\", \"\"]);\n    const [loading, setLoading] = useState(false);\n    const [sending, setSending] = useState(false);\n    const [error, setError] = useState(\"\");\n    const [success, setSuccess] = useState(false);\n    const [resendCooldown, setResendCooldown] = useState(0);\n    const inputRefs = useRef<(HTMLInputElement | null)[]>([]);\n\n    useEffect(() => {\n        sendOtp();\n    }, []);\n\n    useEffect(() => {\n        if (resendCooldown <= 0) return;\n        const t = setTimeout(() => setResendCooldown(c => c - 1), 1000);\n        return () => clearTimeout(t);\n    }, [resendCooldown]);\n\n    async function sendOtp() {\n        setSending(true);\n        setError(\"\");\n        try {\n            await api.sendVerificationOtp();\n            setResendCooldown(60);\n        } catch (err: unknown) {\n            const msg = err instanceof Error ? err.message : \"Failed to send code\";\n            if (msg.includes(\"already verified\")) {\n                router.push(\"/dashboard\");\n                return;\n            }\n            setError(msg);\n        } finally {\n            setSending(false);\n        }\n    }\n\n    function handleDigit(index: number, value: string) {\n        if (!/^\\d*$/.test(value)) return;\n        const next = [...otp];\n        next[index] = value.slice(-1);\n        setOtp(next);\n        if (value && index < 5) {\n            inputRefs.current[index + 1]?.focus();\n        }\n    }\n\n    function handleKeyDown(index: number, e: React.KeyboardEvent<HTMLInputElement>) {\n        if (e.key === \"Backspace\" && !otp[index] && index > 0) {\n            inputRefs.current[index - 1]?.focus();\n        }\n    }\n\n    function handlePaste(e: React.ClipboardEvent) {\n        e.preventDefault();\n        const pasted = e.clipboardData.getData(\"text\").replace(/\\D/g, \"\").slice(0, 6);\n        if (!pasted) return;\n        const next = [...otp];\n        for (let i = 0; i < pasted.length; i++) next[i] = pasted[i];\n        setOtp(next);\n        inputRefs.current[Math.min(pasted.length, 5)]?.focus();\n    }\n\n    async function handleSubmit(e: React.FormEvent) {\n        e.preventDefault();\n        const code = otp.join(\"\");\n        if (code.length < 6) { setError(\"Complete the 6-digit sequence.\"); return; }\n        setLoading(true);\n        setError(\"\");\n        try {\n            await api.verifyEmail(code);\n            setSuccess(true);\n            setTimeout(() => router.push(\"/dashboard\"), 2500);\n        } catch (err: unknown) {\n            setError(err instanceof Error ? err.message : \"Invalid sequence.\");\n            setOtp([\"\", \"\", \"\", \"\", \"\", \"\"]);\n            inputRefs.current[0]?.focus();\n        } finally {\n            setLoading(false);\n        }\n    }\n\n    return (\n        <div className=\"min-h-screen bg-white flex overflow-hidden relative\">\n            <div className=\"absolute inset-0 z-0 pointer-events-none\">\n                <div className=\"absolute top-[-5%] left-[-5%] w-[30%] h-[30%] bg-[#003d73]/5 rounded-full blur-[100px]\" />\n                <div className=\"absolute bottom-[0%] right-[-5%] w-[40%] h-[40%] bg-[#84cc16]/10 rounded-full blur-[120px]\" />\n                <div className=\"landing-grid-overlay opacity-5\" />\n            </div>\n\n            <div className=\"flex-1 flex flex-col relative z-10 w-full\">\n                <div className=\"w-full h-24 px-8 flex items-center justify-between border-b border-gray-50\">\n                    <Link href=\"/\" className=\"flex items-center gap-3\">\n                        <div className=\"w-10 h-10 bg-[#003d73] rounded-xl flex items-center justify-center shadow-lg\">\n                            <span className=\"text-white font-black text-xl tracking-tighter\">E</span>\n                        </div>\n                        <span className=\"font-black text-xl tracking-tighter text-[#003d73]\">EduCare</span>\n                    </Link>\n                </div>\n\n                <div className=\"flex-1 flex items-center justify-center px-8 pb-12\">\n                    <div className=\"w-full max-w-sm\">\n                        <AnimatePresence mode=\"wait\">\n                            {success ? (\n                                <motion.div \n                                    key=\"success\"\n                                    initial={{ opacity: 0, scale: 0.9, y: 20 }}\n                                    animate={{ opacity: 1, scale: 1, y: 0 }}\n                                    className=\"text-center\"\n                                >\n                                    <div className=\"w-20 h-20 bg-[#84cc16]/10 rounded-3xl flex items-center justify-center text-[#84cc16] mx-auto mb-8 shadow-2xl\">\n                                        <Check size={40} />\n                                    </div>\n                                    <h1 className=\"text-4xl font-black text-[#003d73] mb-6 tracking-tighter leading-none\">Identity <br /> Confirmed.</h1>\n                                    <p className=\"text-lg text-gray-400 font-bold mb-10 leading-relaxed\">\n                                        Your communication node is now verified. Initializing dashboard...\n                                    </p>\n                                    <div className=\"flex items-center justify-center gap-3 text-[10px] font-black uppercase tracking-[0.3em] text-[#003d73]\">\n                                        Redirecting <RefreshCcw size={14} className=\"animate-spin\" />\n                                    </div>\n                                </motion.div>\n                            ) : (\n                                <motion.div \n                                    key=\"form\"\n                                    initial={{ opacity: 0, x: 20 }}\n                                    animate={{ opacity: 1, x: 0 }}\n                                    className=\"space-y-10\"\n                                >\n                                    <div>\n                                        <h1 className=\"text-5xl font-black text-[#003d73] mb-4 tracking-tighter leading-none\">\n                                            Sequence <br /> Validation.\n                                        </h1>\n                                        <p className=\"text-lg text-gray-400 font-bold\">\n                                            {sending ? \"Generating verification sequence...\" : \"Enter the 6-digit confirmation code dispatched to your node.\"}\n                                        </p>\n                                    </div>\n\n                                    {error && (\n                                        <div className=\"p-4 bg-red-50 border border-red-100 rounded-2xl flex items-center gap-3\">\n                                            <div className=\"w-2 h-2 rounded-full bg-red-500 animate-pulse\" />\n                                            <span className=\"text-red-600 text-[10px] font-black uppercase tracking-widest\">{error}</span>\n                                        </div>\n                                    )}\n\n                                    <form onSubmit={handleSubmit} className=\"space-y-8\">\n                                        <div className=\"flex gap-3 justify-center\" onPaste={handlePaste}>\n                                            {otp.map((digit, i) => (\n                                                <input\n                                                    key={i}\n                                                    ref={el => { inputRefs.current[i] = el; }}\n                                                    type=\"text\"\n                                                    inputMode=\"numeric\"\n                                                    maxLength={1}\n                                                    value={digit}\n                                                    onChange={e => handleDigit(i, e.target.value)}\n                                                    onKeyDown={e => handleKeyDown(i, e)}\n                                                    className={`w-12 h-16 text-center text-xl font-black rounded-2xl border transition-all outline-none ${digit ? \"bg-white border-[#003d73]/10 text-[#003d73] shadow-lg\" : \"bg-gray-50/50 border-transparent text-gray-300 focus:bg-white focus:border-[#003d73]/10\"}`}\n                                                />\n                                            ))}\n                                        </div>\n\n                                        <button\n                                            type=\"submit\"\n                                            disabled={loading || sending || otp.join(\"\").length < 6}\n                                            className=\"premium-button w-full h-16 bg-[#003d73] text-white text-[10px] font-black uppercase tracking-[0.3em] rounded-2xl shadow-xl active:scale-[0.98] transition-all flex items-center justify-center gap-4 disabled:opacity-50\"\n                                        >\n                                            {loading ? \"VALIDATING SEQUENCE...\" : (\n                                                <>\n                                                    Verify Node Identity\n                                                    <ArrowRight size={18} />\n                                                </>\n                                            )}\n                                        </button>\n                                    </form>\n\n                                    <div className=\"text-center space-y-4\">\n                                        <p className=\"text-[10px] font-black text-gray-300 uppercase tracking-widest\">Didn't receive the transmission?</p>\n                                        <button\n                                            onClick={sendOtp}\n                                            disabled={resendCooldown > 0 || sending}\n                                            className=\"text-[10px] font-black text-[#003d73] uppercase tracking-[0.2em] hover:text-[#84cc16] transition-colors disabled:opacity-40\"\n                                        >\n                                            {resendCooldown > 0\n                                                ? `Retry available in ${resendCooldown}s`\n                                                : sending ? \"Transmitting...\" : \"Re-dispatch Sequence\"}\n                                        </button>\n                                    </div>\n\n                                    <div className=\"pt-6 border-t border-gray-50 flex items-center justify-between\">\n                                        <div className=\"flex items-center gap-3\">\n                                            <ShieldCheck size={16} className=\"text-[#84cc16]\" />\n                                            <p className=\"text-[10px] font-black text-gray-300 uppercase tracking-widest\">Protocol Secured</p>\n                                        </div>\n                                        <Link href=\"/dashboard\" className=\"text-[10px] font-black text-gray-300 uppercase tracking-widest hover:text-[#003d73] transition-colors\">\n                                            Bypass Verification &rarr;\n                                        </Link>\n                                    </div>\n                                </motion.div>\n                            )}\n                        </AnimatePresence>\n                    </div>\n                </div>\n            </div>\n\n            <div className=\"hidden xl:flex w-[400px] bg-[#003d73] p-12 flex-col justify-end relative overflow-hidden\">\n                <div className=\"absolute inset-0 z-0\">\n                    <div className=\"absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-blue-500/10 rounded-full blur-[100px]\" />\n                    <div className=\"landing-grid-overlay opacity-20\" />\n                </div>\n                \n                <div className=\"relative z-10 p-10 premium-panel border-white/10 bg-white/5 shadow-2xl\">\n                    <Sparkles size={32} className=\"text-[#84cc16] mb-8\" />\n                    <h3 className=\"text-3xl font-black text-white leading-none tracking-tighter mb-4\">Node <br /> Verification.</h3>\n                    <p className=\"text-sm text-blue-100/40 font-bold\">This step ensures that your primary communication node is legitimate and securely connected to the EduCare grid.</p>\n                </div>\n            </div>\n        </div>\n    );\n}\n","usedDeprecatedRules":[]},{"filePath":"/Volumes/Volume D/Concilio_Claud/ndps-erp/frontend/src/components/Sidebar.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'FileText' is defined but never used.","line":11,"column":51,"nodeType":"Identifier","messageId":"unusedVar","endLine":11,"endColumn":59,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"FileText"},"fix":{"range":[296,306],"text":""},"desc":"Remove unused variable \"FileText\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'ChevronRight' is defined but never used.","line":12,"column":40,"nodeType":"Identifier","messageId":"unusedVar","endLine":12,"endColumn":52,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"ChevronRight"},"fix":{"range":[345,359],"text":""},"desc":"Remove unused variable \"ChevronRight\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'Home' is defined but never used.","line":14,"column":34,"nodeType":"Identifier","messageId":"unusedVar","endLine":14,"endColumn":38,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"Home"},"fix":{"range":[452,458],"text":""},"desc":"Remove unused variable \"Home\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'BookOpen' is defined but never used.","line":14,"column":40,"nodeType":"Identifier","messageId":"unusedVar","endLine":14,"endColumn":48,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"BookOpen"},"fix":{"range":[458,468],"text":""},"desc":"Remove unused variable \"BookOpen\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'role' is defined but never used.","line":123,"column":25,"nodeType":"Identifier","messageId":"unusedVar","endLine":123,"endColumn":29}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":5,"fixableErrorCount":0,"fixableWarningCount":0,"source":"\"use client\";\n\nimport { useState } from \"react\";\nimport Link from \"next/link\";\nimport { usePathname } from \"next/navigation\";\nimport { useAuth } from \"@/contexts/AuthContext\";\nimport { \n    motion, AnimatePresence \n} from \"framer-motion\";\nimport {\n    LayoutGrid, Users, CalendarCheck, CreditCard, FileText,\n    Wallet, Bell, LogOut, ChevronDown, ChevronRight,\n    Building2, GraduationCap, MessageSquare, ClipboardList,\n    Receipt, Scale, Shield, Bot, Home, BookOpen,\n    Sparkles, Zap, Command, Hexagon\n} from \"lucide-react\";\nimport type { LucideIcon } from \"lucide-react\";\n\ninterface MenuItem {\n    label: string;\n    href?: string;\n    icon: LucideIcon;\n    children?: { label: string; href: string }[];\n}\n\nconst adminMenuItems: MenuItem[] = [\n    { label: \"Dashboard\", href: \"/dashboard\", icon: LayoutGrid },\n    {\n        label: \"Front Desk\", icon: Building2,\n        children: [\n            { label: \"Admission Enquiry\", href: \"/front-desk/enquiry\" },\n            { label: \"Gate Pass\", href: \"/front-desk/gate-pass\" },\n            { label: \"Visitors\", href: \"/front-desk/visitors\" },\n            { label: \"Postal Records\", href: \"/front-desk/postal\" },\n            { label: \"Lost & Found\", href: \"/front-desk/lost-found\" },\n        ],\n    },\n    {\n        label: \"Students\", icon: GraduationCap,\n        children: [\n            { label: \"Active Students\", href: \"/students\" },\n            { label: \"Add Student\", href: \"/students/new\" },\n            { label: \"Inactive Students\", href: \"/students/inactive\" },\n            { label: \"Certificates\", href: \"/students/certificates\" },\n            { label: \"ID Card\", href: \"/students/id-card\" },\n            { label: \"Student Dashboard\", href: \"/students/dashboard\" },\n        ],\n    },\n    {\n        label: \"Human Resource\", icon: Users,\n        children: [\n            { label: \"Manage Employees\", href: \"/staff\" },\n            { label: \"Assign Teachers\", href: \"/hr/assign-teachers\" },\n            { label: \"Staff ID Card\", href: \"/hr/id-card\" },\n            { label: \"HR Dashboard\", href: \"/hr/dashboard\" },\n        ],\n    },\n    {\n        label: \"Attendance\", icon: CalendarCheck,\n        children: [\n            { label: \"Student Attendance\", href: \"/attendance\" },\n            { label: \"Employee Attendance\", href: \"/attendance/staff\" },\n            { label: \"Attendance Dashboard\", href: \"/attendance/dashboard\" },\n        ],\n    },\n    {\n        label: \"Communication\", icon: MessageSquare,\n        children: [\n            { label: \"Bulk Messages\", href: \"/communication/bulk\" },\n            { label: \"SMS Templates\", href: \"/communication/templates\" },\n            { label: \"Delivery Report\", href: \"/communication/reports\" },\n        ],\n    },\n    {\n        label: \"Examination\", icon: ClipboardList,\n        children: [\n            { label: \"Exam Dashboard\", href: \"/exams\" },\n            { label: \"Exam Settings\", href: \"/exams/settings\" },\n            { label: \"Report Card Entries\", href: \"/exams/entries\" },\n            { label: \"Board Configuration\", href: \"/board\" },\n            { label: \"Co-Scholastic Grading\", href: \"/board/co-scholastic\" },\n            { label: \"Generate Report Cards\", href: \"/board/report-cards\" },\n        ],\n    },\n    {\n        label: \"Accounts\", icon: Wallet,\n        children: [\n            { label: \"Income Report\", href: \"/accounts/income\" },\n            { label: \"Manage Expense\", href: \"/accounts/expenses\" },\n            { label: \"Vendor Bills\", href: \"/accounts/vendor-bills\" },\n            { label: \"Accounts Dashboard\", href: \"/accounts/dashboard\" },\n        ],\n    },\n    {\n        label: \"Fees\", icon: CreditCard,\n        children: [\n            { label: \"Fee Payment\", href: \"/fees\" },\n            { label: \"Fee Reports\", href: \"/fees/reports\" },\n            { label: \"Fees Setup\", href: \"/fees/setup\" },\n            { label: \"Fees Dashboard\", href: \"/fees/dashboard\" },\n            { label: \"Payment Instruments\", href: \"/payments/advanced\" },\n        ],\n    },\n    {\n        label: \"Tax & Payroll\", icon: Receipt,\n        children: [\n            { label: \"Tax Configuration\", href: \"/tax\" },\n            { label: \"Salary Structure\", href: \"/tax/salary-structure\" },\n        ],\n    },\n    {\n        label: \"Compliance\", icon: Scale,\n        children: [\n            { label: \"RTE Management\", href: \"/rte\" },\n            { label: \"UDISE+ Reports\", href: \"/udise\" },\n        ],\n    },\n    { label: \"Notices\", href: \"/notices\", icon: Bell },\n    { label: \"Team\", href: \"/team\", icon: Shield },\n    { label: \"AI Assistant\", href: \"/alerts\", icon: Bot },\n];\n\nfunction getMenuForRole(role?: string): MenuItem[] {\n    // Simplified for this overhaul, focus on the Admin experience shown in screenshot\n    return adminMenuItems;\n}\n\nfunction getRoleBadge(role: string) {\n    const map: Record<string, { label: string; cls: string }> = {\n        tenant_admin: { label: \"Admin Node\", cls: \"bg-[#84cc16]/10 text-[#84cc16]\" },\n        owner: { label: \"Principal\", cls: \"bg-[#003d73]/10 text-[#003d73]\" },\n        super_admin: { label: \"Superuser\", cls: \"bg-red-50