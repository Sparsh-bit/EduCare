","endLine":102,"endColumn":21}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":3,"fixableErrorCount":0,"fixableWarningCount":0,"source":"\"use client\";\n\nimport { useState, useEffect, useCallback } from \"react\";\nimport { motion, AnimatePresence } from \"framer-motion\";\nimport { api, reportApiError } from \"@/lib/api\";\nimport type { Class, Section } from \"@/lib/types\";\nimport { \n    CalendarCheck, Users, ChevronRight, CheckCircle2, \n    XCircle, Clock, AlertCircle, Save, Database,\n    Zap, Hexagon\n} from \"lucide-react\";\nimport { toast } from \"react-hot-toast\";\n\ninterface AttendanceStudent { \n    id: number; \n    name: string; \n    roll_number?: string; \n    admission_no?: string; \n    current_roll_no?: string; \n    status?: string; \n}\n\ninterface AttendanceApiStudent { \n    id: number; \n    name?: string; \n    admission_no?: string; \n    current_roll_no?: string; \n    status?: string; \n}\n\nexport default function AttendancePage() {\n    const [classes, setClasses] = useState<Class[]>([]);\n    const [sections, setSections] = useState<Section[]>([]);\n    const [selectedClass, setSelectedClass] = useState(\"\");\n    const [selectedSection, setSelectedSection] = useState(\"\");\n    const [date, setDate] = useState(new Date().toISOString().split(\"T\")[0]);\n    const [students, setStudents] = useState<AttendanceStudent[]>([]);\n    const [loading, setLoading] = useState(false);\n    const [saving, setSaving] = useState(false);\n\n    const fetchAttendance = useCallback(async () => {\n        if (!selectedClass || !selectedSection) return;\n        setLoading(true);\n        try {\n            const data = await api.getClassAttendance(parseInt(selectedClass), parseInt(selectedSection), date);\n            const rows = (data.students || []) as AttendanceApiStudent[];\n            setStudents(rows.map((s) => ({\n                id: s.id,\n                name: s.name || \"\",\n                admission_no: s.admission_no,\n                current_roll_no: s.current_roll_no,\n                status: s.status || undefined,\n            })));\n        }\n        catch (err) { reportApiError(err); } finally { setLoading(false); }\n    }, [selectedClass, selectedSection, date]);\n\n    useEffect(() => { \n        api.getClasses().then(setClasses); \n    }, []);\n\n    useEffect(() => { \n        if (selectedClass) api.getSections(parseInt(selectedClass)).then(setSections); \n    }, [selectedClass]);\n\n    useEffect(() => { \n        if (selectedClass && selectedSection && date) void fetchAttendance(); \n    }, [selectedClass, selectedSection, date, fetchAttendance]);\n\n    const toggleStatus = (studentId: number, status: string) => { \n        setStudents(prev => prev.map(s => s.id === studentId ? { ...s, status } : s)); \n    };\n\n    const markAllPresent = () => { \n        setStudents(prev => prev.map(s => ({ ...s, status: \"P\" }))); \n        toast.success(\"Synchronized: All nodes present\");\n    };\n\n    const saveAttendance = async () => {\n        setSaving(true);\n        try {\n            const records = students.filter(s => s.status).map(s => ({ \n                student_id: s.id, \n                status: s.status as \"P\" | \"A\" | \"L\" | \"H\", \n                class_id: parseInt(selectedClass), \n                section_id: parseInt(selectedSection), \n                date \n            }));\n            \n            if (!records.length) { \n                toast.error(\"Assign status to units first\"); \n                return; \n            }\n            \n            await api.markAttendance({ \n                date, \n                class_id: parseInt(selectedClass), \n                section_id: parseInt(selectedSection), \n                records \n            });\n            toast.success(\"Registry transmission successful\");\n        } catch (err: unknown) { \n            toast.error(\"Transmission failed\"); \n        } finally { \n            setSaving(false); \n        }\n    };\n\n    const statusOptions = [\n        { value: \"P\", label: \"Present\", color: \"emerald\", icon: CheckCircle2 },\n        { value: \"A\", label: \"Absent\", color: \"rose\", icon: XCircle },\n        { value: \"L\", label: \"Leave\", color: \"blue\", icon: Clock },\n        { value: \"HD\", label: \"Delayed\", color: \"amber\", icon: AlertCircle },\n    ];\n\n    const presentCount = students.filter(s => s.status === \"P\").length;\n    const absentCount = students.filter(s => s.status === \"A\").length;\n\n    return (\n        <div className=\"space-y-10 pb-20\">\n            {/* Header */}\n            <div className=\"flex flex-col lg:flex-row lg:items-end justify-between gap-8\">\n                <div>\n                    <div className=\"inline-flex items-center gap-2 px-3 py-1 rounded-full bg-[#003d73]/5 text-[#003d73] text-[9px] font-black uppercase tracking-widest mb-4\">\n                        <Hexagon size={12} className=\"text-[#84cc16]\" />\n                        Protocol: Daily Sync\n                    </div>\n                    <h1 className=\"text-4xl font-black text-[#003d73] tracking-tighter leading-none mb-3\">Attendance Control</h1>\n                    <p className=\"text-sm font-bold text-gray-400\">Verifying presence across academic nodes.</p>\n                </div>\n\n                <div className=\"flex items-center gap-4\">\n                    <div className=\"bg-gray-50 border border-gray-100 rounded-2xl p-2 flex gap-4\">\n                        <div className=\"px-4 py-2 text-center\">\n                            <p className=\"text-[9px] font-black text-gray-300 uppercase tracking-widest mb-1\">Present</p>\n                            <p className=\"text-lg font-black text-emerald-600\">{presentCount}</p>\n                        </div>\n                        <div className=\"w-px bg-gray-200 my-2\" />\n                        <div className=\"px-4 py-2 text-center\">\n                            <p className=\"text-[9px] font-black text-gray-300 uppercase tracking-widest mb-1\">Absent</p>\n                            <p className=\"text-lg font-black text-rose-500\">{absentCount}</p>\n                        </div>\n                    </div>\n                    <button \n                        onClick={markAllPresent}\n                        disabled={!students.length}\n                        className=\"h-14 px-8 rounded-2xl bg-[#003d73] text-white text-[10px] font-black uppercase tracking-widest flex items-center gap-3 hover:scale-[1.02] active:scale-[0.98] transition-all disabled:opacity-40\"\n                    >\n                        <CheckCircle2 size={18} className=\"text-[#84cc16]\" />\n                        Sync All Present\n                    </button>\n                </div>\n            </div>\n\n            {/* Config Panel */}\n            <section className=\"premium-panel p-8 bg-gray-50/50\">\n                <div className=\"grid grid-cols-1 md:grid-cols-3 lg:grid-cols-4 gap-6 items-end\">\n                    <div className=\"space-y-2\">\n                        <label className=\"text-[10px] font-black uppercase tracking-widest text-gray-400 pl-1\">Sync Date</label>\n                        <input \n                            type=\"date\" \n                            value={date} \n                            onChange={e => setDate(e.target.value)} \n                            className=\"w-full h-12 bg-white border-transparent rounded-xl text-xs font-bold text-[#003d73] px-4 focus:ring-4 focus:ring-[#003d73]/5 outline-none transition-all shadow-sm\" \n                        />\n                    </div>\n                    <div className=\"space-y-2\">\n                        <label className=\"text-[10px] font-black uppercase tracking-widest text-gray-400 pl-1\">Level Group</label>\n                        <select \n                            value={selectedClass} \n                            onChange={e => { setSelectedClass(e.target.value); setSelectedSection(\"\"); }} \n                            className=\"w-full h-12 bg-white border-transparent rounded-xl text-xs font-bold text-[#003d73] px-4 focus:ring-4 focus:ring-[#003d73]/5 outline-none transition-all shadow-sm\"\n                        >\n                            <option value=\"\">Select Level</option>\n                            {classes.map((c) => (\n                                <option key={c.id} value={c.id}>\n                                    {String(c.name || \"\").toLowerCase().startsWith(\"class\") ? c.name : \"Class \" + c.name}\n                                </option>\n                            ))}\n                        </select>\n                    </div>\n                    <div className=\"space-y-2\">\n                        <label className=\"text-[10px] font-black uppercase tracking-widest text-gray-400 pl-1\">Target Branch</label>\n                        <select \n                            value={selectedSection} \n                            onChange={e => setSelectedSection(e.target.value)} \n                            className=\"w-full h-12 bg-white border-transparent rounded-xl text-xs font-bold text-[#003d73] px-4 focus:ring-4 focus:ring-[#003d73]/5 outline-none transition-all shadow-sm\"\n                        >\n                            <option value=\"\">Select Branch</option>\n                            {sections.map((s) => <option key={s.id} value={s.id}>{s.name}</option>)}\n                        </select>\n                    </div>\n                </div>\n            </section>\n\n            {/* Registry List */}\n            <section className=\"premium-panel bg-white overflow-hidden p-0\">\n                <AnimatePresence mode=\"wait\">\n                    {loading ? (\n                        <motion.div \n                            initial={{ opacity: 0 }} animate={{ opacity: 1 }} exit={{ opacity: 0 }}\n                            className=\"py-32 text-center\"\n                        >\n                            <div className=\"w-12 h-12 border-4 border-[#003d73]/5 border-t-[#003d73] rounded-full animate-spin mx-auto mb-4\" />\n                            <p className=\"text-[10px] font-black uppercase tracking-[0.3em] text-gray-300\">Retrieving Unit List...</p>\n                        </motion.div>\n                    ) : students.length > 0 ? (\n                        <div className=\"overflow-x-auto\">\n                            <table className=\"w-full text-left border-collapse\">\n                                <thead>\n                                    <tr className=\"bg-gray-50/50 border-b border-gray-50\">\n                                        <th className=\"px-8 py-5 text-[10px] font-black uppercase tracking-widest text-gray-400\">Node Cluster</th>\n                                        <th className=\"px-8 py-5 text-[10px] font-black uppercase tracking-widest text-gray-400\">Unit Identifier</th>\n                                        <th className=\"px-8 py-5 text-[10px] font-black uppercase tracking-widest text-gray-400 text-center w-[400px]\">Protocol Configuration</th>\n                                    </tr>\n                                </thead>\n                                <tbody className=\"divide-y divide-gray-50\">\n                                    {students.map((student) => (\n                                        <tr key={student.id} className=\"group hover:bg-[#003d73]/5 transition-colors\">\n                                            <td className=\"px-8 py-6\">\n                                                <div className=\"flex items-center gap-4\">\n                                                    <div className=\"w-12 h-12 rounded-2xl bg-gray-50 border border-gray-100 flex items-center justify-center font-black text-sm text-[#003d73] group-hover:bg-[#003d73] group-hover:text-white transition-all\">\n                                                        {student.name.charAt(0)}\n                                                    </div>\n                                                    <div>\n                                                        <p className=\"text-sm font-black text-[#003d73] tracking-tight leading-none\">{student.name}</p>\n                                                        <p className=\"text-[10px] font-bold text-gray-300 uppercase tracking-widest mt-2\">Active Node</p>\n                                                    </div>\n                                                </div>\n                                            </td>\n                                            <td className=\"px-8 py-6\">\n                                                <div className=\"flex flex-col gap-1\">\n                                                     <div className=\"flex items-center gap-2 text-xs font-bold text-gray-600\">\n                                                         <Database size={12} className=\"text-[#84cc16]\" />\n                                                         ADM: {student.admission_no}\n                                                     </div>\n                                                     <p className=\"text-[10px] font-black text-gray-300\">ROLL: {student.current_roll_no || \"—\"}</p>\n                                                </div>\n                                            </td>\n                                            <td className=\"px-8 py-6\">\n                                                <div className=\"flex justify-center gap-2\">\n                                                    {statusOptions.map((opt) => {\n                                                        const Icon = opt.icon;\n                                                        const isSelected = student.status === opt.value;\n                                                        return (\n                                                            <button\n                                                                key={opt.value}\n                                                                onClick={() => toggleStatus(student.id, opt.value)}\n                                                                className={`\n                                                                    flex items-center gap-2 px-4 py-2 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all\n                                                                    ${isSelected \n                                                                        ? `bg-[#003d73] text-white shadow-xl shadow-[#003d73]/20`\n                                                                        : \"bg-white border border-gray-100 text-gray-400 hover:border-[#003d73]/20\"\n                                                                    }\n                                                                `}\n                                                            >\n                                                                <Icon size={14} className={isSelected ? \"text-[#84cc16]\" : \"opacity-40\"} />\n                                                                {opt.label}\n                                                            </button>\n                                                        );\n                                                    })}\n                                                </div>\n                                            </td>\n                                        </tr>\n                                    ))}\n                                </tbody>\n                            </table>\n                        </div>\n                    ) : (\n                        <div className=\"py-32 text-center flex flex-col items-center gap-6\">\n                            <div className=\"w-20 h-20 bg-gray-50 rounded-[2rem] flex items-center justify-center text-gray-200\">\n                                <Users size={40} />\n                            </div>\n                            <div>\n                                <h3 className=\"text-xl font-black text-[#003d73] tracking-tighter uppercase\">Initialize Scan</h3>\n                                <p className=\"text-sm font-bold text-gray-400 mt-2\">Select class and section nodes to reveal registry.</p>\n                            </div>\n                        </div>\n                    )}\n                </AnimatePresence>\n            </section>\n\n            {/* Floating Action Button */}\n            <AnimatePresence>\n                {students.length > 0 && (\n                    <motion.div \n                        initial={{ y: 100, opacity: 0 }}\n                        animate={{ y: 0, opacity: 1 }}\n                        className=\"fixed bottom-10 right-10 z-[80]\"\n                    >\n                        <button\n                            onClick={saveAttendance}\n                            disabled={saving}\n                            className=\"h-20 px-10 rounded-[2.5rem] bg-[#003d73] text-white flex items-center gap-4 hover:scale-105 active:scale-95 transition-all shadow-2xl shadow-[#003d73]/40\"\n                        >\n                            <div className=\"w-12 h-12 rounded-2xl bg-[#84cc16] flex items-center justify-center text-[#003d73]\">\n                                {saving ? <Zap className=\"animate-spin\" size={24} /> : <Save size={24} />}\n                            </div>\n                            <div className=\"text-left\">\n                                <p className=\"text-[10px] font-black uppercase tracking-[0.2em] opacity-60\">Transmission Ready</p>\n                                <p className=\"text-sm font-black uppercase tracking-widest\">Commit to Registry</p>\n                            </div>\n                        </button>\n                    </motion.div>\n                )}\n            </AnimatePresence>\n        </div>\n    );\n}\n","usedDeprecatedRules":[]},{"filePath":"/Volumes/Volume D/Concilio_Claud/ndps-erp/frontend/src/app/(dashboard)/attendance/staff/page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Volumes/Volume D/Concilio_Claud/ndps-erp/frontend/src/app/(dashboard)/board/co-scholastic/page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Volumes/Volume D/Concilio_Claud/ndps-erp/frontend/src/app/(dashboard)/board/page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Volumes/Volume D/Concilio_Claud/ndps-erp/frontend/src/app/(dashboard)/board/report-cards/page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Volumes/Volume D/Concilio_Claud/ndps-erp/frontend/src/app/(dashboard)/communication/bulk/page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Volumes/Volume D/Concilio_Claud/ndps-erp/frontend/src/app/(dashboard)/communication/reports/page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Volumes/Volume D/Concilio_Claud/ndps-erp/frontend/src/app/(dashboard)/communication/templates/page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Volumes/Volume D/Concilio_Claud/ndps-erp/frontend/src/app/(dashboard)/dashboard/page.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'RotateCcw' is defined but never used.","line":11,"column":5,"nodeType":"Identifier","messageId":"unusedVar","endLine":11,"endColumn":14,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"RotateCcw"},"fix":{"range":[223,238],"text":""},"desc":"Remove unused variable \"RotateCcw\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'confirmingImport' is assigned a value but never used.","line":112,"column":12,"nodeType":"Identifier","messageId":"unusedVar","endLine":112,"endColumn":28},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'revertingImport' is assigned a value but never used.","line":113,"column":12,"nodeType":"Identifier","messageId":"unusedVar","endLine":113,"endColumn":27},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'setRevertingImport' is assigned a value but never used.","line":113,"column":29,"nodeType":"Identifier","messageId":"unusedVar","endLine":113,"endColumn":47},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'importResult' is assigned a value but never used.","line":116,"column":12,"nodeType":"Identifier","messageId":"unusedVar","endLine":116,"endColumn":24},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'error' is defined but never used.","line":146,"column":18,"nodeType":"Identifier","messageId":"unusedVar","endLine":146,"endColumn":23},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'error' is defined but never used.","line":163,"column":18,"nodeType":"Identifier","messageId":"unusedVar","endLine":163,"endColumn":23},{"ruleId":"react/jsx-no-undef","severity":2,"message":"'Hexagon' is not defined.","line":225,"column":22,"nodeType":"JSXIdentifier","messageId":"undefined","endLine":225,"endColumn":29},{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":309,"column":90,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":309,"endColumn":93,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[13008,13011],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[13008,13011],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]}],"suppressedMessages":[],"errorCount":2,"fatalErrorCount":0,"warningCount":7,"fixableErrorCount":0,"fixableWarningCount":0,"source":"\"use client\";\n\nimport { useEffect, useMemo, useState, type ChangeEvent } from \"react\";\nimport { motion } from \"framer-motion\";\nimport {\n    Activity,\n    AlertTriangle,\n    CalendarDays,\n    FileSpreadsheet,\n    IndianRupee,\n    RotateCcw,\n    School,\n    UploadCloud,\n    Users,\n    ArrowUpRight,\n    TrendingUp,\n    ShieldCheck,\n    Zap,\n    type LucideIcon,\n} from \"lucide-react\";\nimport { toast } from \"react-hot-toast\";\nimport { api, reportApiError } from \"@/lib/api\";\nimport { useAuth } from \"@/contexts/AuthContext\";\nimport type { DashboardStats, Exam } from \"@/lib/types\";\n\n// Types\ntype RecentActivityItem = {\n    id?: number;\n    type?: string;\n    description?: string;\n    created_at: string;\n    user_name?: string;\n};\n\ntype StatTile = {\n    title: string;\n    value: string;\n    helper: string;\n    icon: LucideIcon;\n    trend: string;\n    color: string;\n};\n\ntype StudentImportPreview = {\n    status: \"preview_ready\";\n    batch_id: number;\n    file_name: string;\n    total_rows_detected: number;\n    valid_students: number;\n    invalid_rows: number;\n    errors: Array<{ row: number; errors: string[] }>;\n    preview_records: Array<Record<string, unknown>>;\n};\n\ntype StudentImportResult = {\n    status: \"completed\";\n    batch_id: number;\n    students_added: number;\n    skipped_rows: number;\n    failed: Array<{ row: number; reason: string; name?: string }>;\n};\n\n// Variants\nconst containerVariants = {\n    hidden: { opacity: 0 },\n    show: {\n        opacity: 1,\n        transition: { staggerChildren: 0.1 },\n    },\n};\n\nconst itemVariants = {\n    hidden: { opacity: 0, y: 20 },\n    show: { opacity: 1, y: 0, transition: { duration: 0.6, ease: [0.22, 1, 0.36, 1] } },\n};\n\n// Helpers\nfunction formatAmount(amount: number): string {\n    if (!Number.isFinite(amount)) return \"₹0\";\n    if (amount >= 1_00_00_000) return `₹${(amount / 1_00_00_000).toFixed(1)}Cr`;\n    if (amount >= 1_00_000) return `₹${(amount / 1_00_000).toFixed(1)}L`;\n    return `₹${Math.round(amount).toLocaleString(\"en-IN\")}`;\n}\n\nfunction formatDate(dateString?: string): string {\n    if (!dateString) return \"TBD\";\n    const date = new Date(dateString);\n    if (Number.isNaN(date.getTime())) return \"TBD\";\n    return date.toLocaleDateString(\"en-IN\", { day: \"2-digit\", month: \"short\" });\n}\n\nfunction formatRelative(dateString: string): string {\n    const date = new Date(dateString);\n    if (Number.isNaN(date.getTime())) return \"Unknown\";\n    const diffMs = Date.now() - date.getTime();\n    const diffMins = Math.floor(diffMs / (1000 * 60));\n    if (diffMins < 1) return \"Now\";\n    if (diffMins < 60) return `${diffMins}m`;\n    const diffHours = Math.floor(diffMins / 60);\n    if (diffHours < 24) return `${diffHours}h`;\n    return `${Math.floor(diffHours / 24)}d`;\n}\n\nexport default function DashboardPage() {\n    const { user } = useAuth();\n    const [stats, setStats] = useState<DashboardStats | null>(null);\n    const [upcomingExams, setUpcomingExams] = useState<Exam[]>([]);\n    const [recentActivity, setRecentActivity] = useState<RecentActivityItem[]>([]);\n    const [loading, setLoading] = useState(true);\n\n    const [importing, setImporting] = useState(false);\n    const [confirmingImport, setConfirmingImport] = useState(false);\n    const [revertingImport, setRevertingImport] = useState(false);\n    const [duplicateStrategy, setDuplicateStrategy] = useState<\"skip\" | \"replace\" | \"add_both\">(\"skip\");\n    const [importPreview, setImportPreview] = useState<StudentImportPreview | null>(null);\n    const [importResult, setImportResult] = useState<StudentImportResult | null>(null);\n\n    const refreshDashboard = async () => {\n        try {\n            const [statsData, examsData, activityData] = await Promise.all([\n                api.getDashboardStats(),\n                api.getUpcomingExams(),\n                api.getRecentActivity(),\n            ]);\n            setStats(statsData);\n            setUpcomingExams(Array.isArray(examsData) ? examsData : []);\n            setRecentActivity(Array.isArray(activityData?.data) ? activityData.data : []);\n        } catch (error) {\n            reportApiError(error);\n        }\n    };\n\n    useEffect(() => {\n        refreshDashboard().finally(() => setLoading(false));\n    }, []);\n\n    const onImportStudents = async (event: ChangeEvent<HTMLInputElement>) => {\n        const file = event.target.files?.[0];\n        if (!file) return;\n        try {\n            setImporting(true);\n            const preview = await api.importStudentsFile(file);\n            setImportPreview(preview as StudentImportPreview);\n            setImportResult(null);\n            toast.success(\"Ready for deployment\");\n        } catch (error) {\n            toast.error(\"Protocol failure\");\n        } finally {\n            setImporting(false);\n            event.target.value = \"\";\n        }\n    };\n\n    const onConfirmImport = async () => {\n        if (!importPreview?.batch_id) return;\n        try {\n            setConfirmingImport(true);\n            const result = await api.confirmStudentImportBatch(importPreview.batch_id, duplicateStrategy);\n            setImportResult(result as StudentImportResult);\n            setImportPreview(null);\n            toast.success(\"Identity synchronization complete\");\n            refreshDashboard();\n        } catch (error) {\n            toast.error(\"Confirmation rejected\");\n        } finally {\n            setConfirmingImport(false);\n        }\n    };\n\n    const statTiles = useMemo<StatTile[]>(() => {\n        return [\n            {\n                title: \"Student Node\",\n                value: (stats?.students?.total ?? 0).toLocaleString(),\n                helper: \"Active enrollments\",\n                icon: Users,\n                trend: \"+12%\",\n                color: \"text-blue-600\",\n            },\n            {\n                title: \"Asset Distribution\",\n                value: (stats?.staff?.total ?? 0).toLocaleString(),\n                helper: \"Human capital units\",\n                icon: School,\n                trend: \"+2%\",\n                color: \"text-emerald-600\",\n            },\n            {\n                title: \"Live Attendance\",\n                value: `${(stats?.attendance?.percentage ?? 0).toFixed(1)}%`,\n                helper: \"Current daily sync\",\n                icon: Activity,\n                trend: \"Optimal\",\n                color: \"text-amber-500\",\n            },\n            {\n                title: \"Fiscal Flow\",\n                value: formatAmount(stats?.fees?.total_collected ?? 0),\n                helper: \"Recorded revenue\",\n                icon: IndianRupee,\n                trend: \"+8.4%\",\n                color: \"text-[#003d73]\",\n            },\n        ];\n    }, [stats]);\n\n    if (loading) {\n        return (\n            <div className=\"space-y-10 animate-pulse\">\n                <div className=\"h-40 rounded-[3rem] bg-gray-50 border border-gray-100\" />\n                <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8\">\n                    {[1, 2, 3, 4].map(i => (\n                        <div key={i} className=\"h-48 rounded-[2.5rem] bg-gray-50 border border-gray-100\" />\n                    ))}\n                </div>\n            </div>\n        );\n    }\n\n    return (\n        <motion.div variants={containerVariants} initial=\"hidden\" animate=\"show\" className=\"space-y-12 pb-20\">\n            {/* Welcome Banner */}\n            <motion.section variants={itemVariants} className=\"premium-panel p-10 relative overflow-hidden group\">\n                <div className=\"absolute top-0 right-0 p-10 opacity-5 group-hover:scale-110 transition-transform\">\n                    <Hexagon size={120} className=\"text-[#003d73]\" />\n                </div>\n                <div className=\"relative z-10 flex flex-col md:flex-row md:items-end justify-between gap-8\">\n                    <div>\n                        <div className=\"inline-flex items-center gap-2 px-3 py-1 rounded-full bg-[#003d73]/5 text-[#003d73] text-[9px] font-black uppercase tracking-widest mb-6\">\n                            <ShieldCheck size={12} className=\"text-[#84cc16]\" />\n                            System Active: {stats?.academic_year || \"2025-26\"}\n                        </div>\n                        <h2 className=\"text-4xl md:text-5xl font-black text-[#003d73] tracking-tighter leading-none mb-4\">\n                            Welcome, <span className=\"text-gradient\">{user?.name?.split(\" \")[0] || \"Administrator\"}</span>\n                        </h2>\n                        <p className=\"text-lg text-gray-400 font-bold max-w-xl\">\n                            Institutional protocols are running at peak efficiency. Your terminal is synchronized with current school operations.\n                        </p>\n                    </div>\n                    \n                    <div className=\"flex gap-4\">\n                        <div className=\"px-6 py-4 rounded-2xl bg-gray-50 border border-gray-100 text-center min-w-[120px]\">\n                            <p className=\"text-[10px] font-black uppercase tracking-widest text-gray-300 mb-1\">Status</p>\n                            <div className=\"flex items-center justify-center gap-2\">\n                                <div className=\"w-2 h-2 rounded-full bg-[#84cc16] animate-pulse\" />\n                                <span className=\"text-sm font-black text-[#003d73]\">STABLE</span>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </motion.section>\n\n            {/* Quick Actions / Import */}\n            <motion.section variants={itemVariants} className=\"premium-panel p-8 bg-[#003d73] text-white\">\n                <div className=\"flex flex-col md:flex-row items-center justify-between gap-8\">\n                    <div className=\"flex items-center gap-6\">\n                        <div className=\"w-16 h-16 bg-white/10 rounded-3xl flex items-center justify-center text-[#84cc16]\">\n                            <UploadCloud size={32} />\n                        </div>\n                        <div>\n                            <h3 className=\"text-xl font-black tracking-tight leading-none mb-2\">Bulk Data Partitioning</h3>\n                            <p className=\"text-sm font-medium text-white/50 italic\">Push XLSX/CSV datasets to student nodes.</p>\n                        </div>\n                    </div>\n\n                    <div className=\"flex items-center gap-4\">\n                        <input\n                            id=\"import-node\"\n                            type=\"file\"\n                            accept=\".xlsx,.csv\"\n                            className=\"hidden\"\n                            onChange={onImportStudents}\n                            disabled={importing}\n                        />\n                        <label\n                            htmlFor=\"import-node\"\n                            className=\"h-14 px-8 rounded-2xl bg-[#84cc16] text-[#003d73] text-[11px] font-black uppercase tracking-[0.2em] flex items-center gap-3 cursor-pointer hover:scale-[1.02] active:scale-[0.98] transition-all shadow-xl shadow-black/10\"\n                        >\n                            {importing ? \"SYCHRONIZING...\" : (<><Zap size={18} /> Deploy Dataset</>)}\n                        </label>\n                    </div>\n                </div>\n\n                {importPreview && (\n                    <motion.div \n                        initial={{ opacity: 0, y: 10 }} animate={{ opacity: 1, y: 0 }}\n                        className=\"mt-8 p-8 rounded-3xl bg-white/5 border border-white/10 space-y-8\"\n                    >\n                         <div className=\"flex items-center justify-between\">\n                             <div className=\"flex items-center gap-3\">\n                                 <FileSpreadsheet className=\"text-[#84cc16]\" size={20} />\n                                 <span className=\"text-sm font-black uppercase tracking-widest\">{importPreview.file_name}</span>\n                             </div>\n                             <div className=\"flex gap-6\">\n                                 <div className=\"text-center\">\n                                     <p className=\"text-[10px] uppercase font-black opacity-40\">Valid</p>\n                                     <p className=\"text-lg font-black text-[#84cc16]\">{importPreview.valid_students}</p>\n                                 </div>\n                                 <div className=\"text-center text-rose-400\">\n                                     <p className=\"text-[10px] uppercase font-black opacity-40\">Errors</p>\n                                     <p className=\"text-lg font-black\">{importPreview.invalid_rows}</p>\n                                 </div>\n                             </div>\n                         </div>\n                         \n                         <div className=\"flex gap-4\">\n                             <select\n                                 value={duplicateStrategy}\n                                 onChange={(e) => setDuplicateStrategy(e.target.value as any)}\n                                 className=\"bg-white/10 border border-white/10 rounded-xl px-4 text-xs font-black uppercase tracking-widest text-[#84cc16] outline-none\"\n                             >\n                                 <option value=\"skip\">Skip DUPES</option>\n                                 <option value=\"replace\">Overwrite</option>\n                             </select>\n                             <button\n                                 onClick={onConfirmImport}\n                                 className=\"h-12 px-6 rounded-xl bg-white text-[#003d73] text-[10px] font-black uppercase tracking-widest hover:bg-[#84cc16] transition-colors\"\n                             >\n                                 Finalize Protocol\n                             </button>\n                             <button onClick={() => setImportPreview(null)} className=\"text-white/40 text-[10px] font-black uppercase tracking-widest hover:text-white transition-colors\">Abondon</button>\n                         </div>\n                    </motion.div>\n                )}\n            </motion.section>\n\n            {/* Metrics Grid */}\n            <motion.section variants={itemVariants} className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8\">\n                {statTiles.map((tile, idx) => {\n                    const Icon = tile.icon;\n                    return (\n                        <article key={idx} className=\"premium-panel p-8 group hover:border-[#003d73]/20\">\n                            <div className=\"flex items-start justify-between mb-8\">\n                                <div className={`w-14 h-14 rounded-2xl bg-gray-50 flex items-center justify-center ${tile.color} group-hover:scale-110 transition-transform`}>\n                                    <Icon size={24} />\n                                </div>\n                                <div className=\"flex items-center gap-1.5 px-2 py-1 rounded-full bg-emerald-50 text-emerald-600 text-[9px] font-black uppercase\">\n                                    <TrendingUp size={10} />\n                                    {tile.trend}\n                                </div>\n                            </div>\n                            <h4 className=\"text-[10px] font-black uppercase tracking-[0.3em] text-gray-300 mb-2\">{tile.title}</h4>\n                            <p className=\"text-4xl font-black text-[#003d73] tracking-tighter mb-2 leading-none\">{tile.value}</p>\n                            <p className=\"text-xs font-bold text-gray-400\">{tile.helper}</p>\n                        </article>\n                    );\n                })}\n            </motion.section>\n\n            {/* Detailed Analytics Grid */}\n            <motion.section variants={itemVariants} className=\"grid grid-cols-1 xl:grid-cols-3 gap-8\">\n                {/* Exams */}\n                <div className=\"xl:col-span-2 premium-panel p-10\">\n                    <div className=\"flex items-center justify-between mb-10\">\n                        <div>\n                            <h3 className=\"text-2xl font-black text-[#003d73] tracking-tighter\">Assessment Feed</h3>\n                            <p className=\"text-xs font-bold text-gray-400 uppercase tracking-widest mt-1\">Imminent evaluations</p>\n                        </div>\n                        <CalendarDays className=\"text-[#84cc16]\" size={28} />\n                    </div>\n                    \n                    <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4\">\n                        {upcomingExams.length === 0 ? (\n                            <div className=\"col-span-2 py-12 text-center bg-gray-50 rounded-3xl border border-dashed border-gray-200\">\n                                 <p className=\"text-xs font-black uppercase tracking-widest text-gray-300\">No imminent evaluations scheduled</p>\n                            </div>\n                        ) : (\n                            upcomingExams.slice(0, 4).map((exam) => (\n                                <div key={exam.id} className=\"p-6 rounded-2xl bg-gray-50/50 border border-gray-100 hover:bg-white hover:shadow-xl hover:shadow-gray-100 transition-all group\">\n                                    <div className=\"flex items-center justify-between mb-4\">\n                                        <span className=\"text-[9px] font-black uppercase tracking-widest text-[#84cc16] bg-[#84cc16]/5 px-2 py-0.5 rounded\">Terminal {exam.term}</span>\n                                        <ArrowUpRight size={16} className=\"text-gray-200 group-hover:text-[#003d73] transition-colors\" />\n                                    </div>\n                                    <h5 className=\"text-lg font-black text-[#003d73] tracking-tight mb-1\">{exam.name}</h5>\n                                    <p className=\"text-xs font-bold text-gray-400 mb-6\">{exam.class_name || \"Enterprise\"}</p>\n                                    <div className=\"flex items-center gap-2\">\n                                        <div className=\"w-1.5 h-1.5 rounded-full bg-[#84cc16]\" />\n                                        <p className=\"text-[10px] font-black uppercase tracking-widest text-gray-400\">Deployed: {formatDate(exam.start_date)}</p>\n                                    </div>\n                                </div>\n                            ))\n                        )}\n                    </div>\n                </div>\n\n                {/* Class Mix / Capacity */}\n                <div className=\"premium-panel p-10 flex flex-col\">\n                    <div className=\"mb-10\">\n                        <h3 className=\"text-2xl font-black text-[#003d73] tracking-tighter\">Capacity Mix</h3>\n                        <p className=\"text-xs font-bold text-gray-400 uppercase tracking-widest mt-1\">Node density distribution</p>\n                    </div>\n                    \n                    <div className=\"space-y-8 flex-1\">\n                        {(stats?.students?.by_class || []).slice(0, 6).map((item, idx) => {\n                            const total = stats?.students?.total || 1;\n                            const share = Math.round((item.count / total) * 100);\n                            return (\n                                <div key={idx} className=\"space-y-3\">\n                                    <div className=\"flex justify-between items-end\">\n                                        <p className=\"text-[11px] font-black uppercase tracking-widest text-[#003d73]\">{item.class_name}</p>\n                                        <p className=\"text-[10px] font-bold text-gray-400\">{item.count} Nodes</p>\n                                    </div>\n                                    <div className=\"h-1.5 w-full bg-gray-100 rounded-full overflow-hidden\">\n                                        <motion.div \n                                            initial={{ width: 0 }}\n                                            whileInView={{ width: `${share}%` }}\n                                            transition={{ duration: 1, delay: idx * 0.1 }}\n                                            viewport={{ once: true }}\n                                            className=\"h-full bg-gradient-to-r from-[#003d73] to-[#84cc16]\" \n                                        />\n                                    </div>\n                                </div>\n                            );\n                        })}\n                    </div>\n                </div>\n            </motion.section>\n\n            {/* Activity Stream */}\n            <motion.section variants={itemVariants} className=\"premium-panel p-10\">\n                <div className=\"flex items-center gap-4 mb-10\">\n                    <div className=\"w-10 h-10 rounded-2xl bg-amber-50 flex items-center justify-center text-amber-600\">\n                        <AlertTriangle size={20} />\n                    </div>\n                    <h3 className=\"text-2xl font-black text-[#003d73] tracking-tighter\">Transmission Feed</h3>\n                </div>\n\n                <div className=\"space-y-4\">\n                    {recentActivity.length === 0 ? (\n                        <div className=\"py-12 text-center bg-gray-50 rounded-3xl\">\n                             <p className=\"text-[10px] font-black uppercase tracking-widest text-gray-300\">No recent transmissions recorded</p>\n                        </div>\n                    ) : (\n                        recentActivity.slice(0, 6).map((entry, idx) => (\n                            <div key={idx} className=\"flex items-center justify-between p-6 rounded-2xl border border-gray-50 bg-gray-50/20 hover:bg-white hover:border-gray-100 transition-all group\">\n                                <div className=\"flex items-center gap-6\">\n                                     <div className=\"w-2 h-2 rounded-full bg-gray-200 group-hover:bg-[#84cc16] transition-colors\" />\n                                     <div>\n                                         <p className=\"text-sm font-bold text-[#003d73] mb-1\">{entry.description}</p>\n                                         <p className=\"text-[9px] font-black uppercase tracking-widest text-gray-400\">\n                                            {entry.type} · Principal: {entry.user_name || \"System\"}\n                                         </p>\n                                     </div>\n                                </div>\n                                <span className=\"text-[10px] font-black text-gray-300 uppercase tracking-widest