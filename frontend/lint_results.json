or}</span>\n                            </motion.div>\n                        )}\n                    </AnimatePresence>\n\n                    <form onSubmit={handleSubmit} className=\"space-y-6\">\n                        <div className=\"space-y-2\">\n                             <div className=\"flex items-center justify-between px-2\">\n                                <label className=\"text-[10px] font-black text-gray-400 uppercase tracking-widest\">School Identity</label>\n                             </div>\n                             <div className=\"relative group\">\n                                <div className=\"absolute left-5 top-1/2 -translate-y-1/2 text-gray-400 group-focus-within:text-[#003d73] transition-colors\">\n                                    <Building2 size={18} />\n                                </div>\n                                <input\n                                    type=\"text\"\n                                    value={schoolCode}\n                                    onChange={(e) => setSchoolCode(e.target.value.toUpperCase())}\n                                    placeholder=\"SCHOOL CODE\"\n                                    required\n                                    className=\"w-full h-16 pl-14 pr-6 bg-gray-50/50 border border-transparent rounded-[1.25rem] text-[#003d73] text-sm font-black tracking-[0.15em] focus:bg-white focus:border-[#003d73]/20 focus:ring-4 focus:ring-[#003d73]/5 outline-none transition-all placeholder:text-gray-300 placeholder:tracking-normal placeholder:font-bold\"\n                                />\n                             </div>\n                        </div>\n\n                        <div className=\"space-y-2\">\n                             <div className=\"px-2\">\n                                <label className=\"text-[10px] font-black text-gray-400 uppercase tracking-widest\">User Identifier</label>\n                             </div>\n                             <div 