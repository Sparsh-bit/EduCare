{
  "_comment": "EduCare ERP — Frontend ECS Task Definition Template",
  "_instructions": [
    "Replace ALL <PLACEHOLDER> values before registering.",
    "NEXT_PUBLIC_* vars are baked into the image at build time via Docker ARGs.",
    "Register with: aws ecs register-task-definition --cli-input-json file://task-definition-frontend.json"
  ],
  "family": "ndps-erp-frontend",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::<AWS_ACCOUNT_ID>:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::<AWS_ACCOUNT_ID>:role/ndps-erp-task-role",
  "containerDefinitions": [
    {
      "name": "ndps-erp-frontend",
      "image": "<AWS_ACCOUNT_ID>.dkr.ecr.<AWS_REGION>.amazonaws.com/ndps-erp-frontend:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "NODE_ENV", "value": "production" },
        { "name": "PORT",     "value": "3000" }
      ],
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -f http://localhost:3000/ || exit 1"],
        "interval": 30,
        "timeout": 10,
        "retries": 3,
        "startPeriod": 60
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/ndps-erp-frontend",
          "awslogs-region": "<AWS_REGION>",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group": "true"
        }
      },
      "readonlyRootFilesystem": false,
      "linuxParameters": {
        "initProcessEnabled": true
      }
    }
  ],
  "volumes": []
}
